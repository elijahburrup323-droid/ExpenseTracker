<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Assets Dashboard</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Snapshot of non-investment assets</p>
      </div>
      <div class="flex items-center space-x-2">
        <%= link_to assets_list_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition" do %>
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Asset
        <% end %>
      </div>
    </div>
  </div>

  <%# Dashboard Metrics — 3-column centered grid %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-6">
    <%# Total Asset Value %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Asset Value</p>
      <p class="mt-2 text-2xl font-bold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@total_asset_value) %></p>
      <p class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">Included in net worth</p>
    </div>

    <%# Total Excluded Assets %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Excluded Assets</p>
      <p class="mt-2 text-2xl font-bold text-gray-500 dark:text-gray-400 tabular-nums"><%= number_to_currency(@total_excluded) %></p>
      <p class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">Not in net worth</p>
    </div>

    <%# Asset Count %>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Asset Count</p>
      <p class="mt-2 text-2xl font-bold text-brand-600 dark:text-brand-400 tabular-nums"><%= @asset_count %></p>
      <p class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">Active assets</p>
    </div>
  </div>

  <%# Asset Type Breakdown %>
  <div class="mt-8">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Asset Type Breakdown</h2>
    <% if @type_breakdown.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% type_colors = %w[purple blue emerald amber sky rose] %>
        <% @type_breakdown.each_with_index do |t, i| %>
          <% c = type_colors[i % type_colors.length] %>
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-5">
            <div class="flex items-center space-x-3">
              <span class="w-10 h-10 rounded-lg bg-<%= c %>-100 dark:bg-<%= c %>-900/30 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-<%= c %>-500 dark:text-<%= c %>-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/>
                </svg>
              </span>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900 dark:text-white truncate"><%= t[:name] %></p>
                <p class="text-xs text-gray-500 dark:text-gray-400"><%= t[:count] %> asset<%= t[:count] == 1 ? "" : "s" %></p>
              </div>
            </div>
            <p class="mt-3 text-lg font-bold text-gray-900 dark:text-white tabular-nums text-right"><%= number_to_currency(t[:total]) %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
        <svg class="mx-auto h-10 w-10 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/>
        </svg>
        <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">No assets yet. <%= link_to "Add your first asset", assets_list_path, class: "text-brand-600 dark:text-brand-400 hover:text-brand-700 font-medium" %> to get started.</p>
      </div>
    <% end %>
  </div>
</div>
