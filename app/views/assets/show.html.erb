<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="asset-detail"
     data-asset-detail-asset-id-value="<%= @asset.id %>"
     data-asset-detail-api-url-value="<%= api_assets_path %>"
     data-asset-detail-types-url-value="<%= api_asset_types_path %>"
     data-asset-detail-valuations-url-value="<%= api_asset_asset_valuations_path(@asset) %>"
     data-asset-detail-csrf-token-value="<%= form_authenticity_token %>"
     data-asset-detail-list-url-value="<%= assets_list_path %>">

  <%# ===== Page Header (sticky) ===== %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-center space-x-3 mb-1">
          <a href="<%= assets_list_path %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white" data-role="asset-name"><%= @asset.name %></h1>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 ml-8" data-role="asset-type"><%= @asset.asset_type&.name %></p>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button"
                data-action="click->asset-detail#openAddValuation"
                class="inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-lg text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition shadow-sm">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Valuation
        </button>
        <button type="button"
                data-action="click->asset-detail#startEdit"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-brand-600 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit Asset
        </button>
      </div>
    </div>
  </div>

  <%# ===== Tab Navigation ===== %>
  <div class="border-b border-gray-200 dark:border-gray-700 mt-4">
    <nav class="flex space-x-6 -mb-px" aria-label="Tabs">
      <button type="button" data-asset-detail-target="tabBtn" data-tab="overview"
              data-action="click->asset-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-brand-600 text-brand-600 dark:border-brand-400 dark:text-brand-400 transition">
        Overview
      </button>
      <button type="button" data-asset-detail-target="tabBtn" data-tab="valuations"
              data-action="click->asset-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Valuation History
      </button>
      <button type="button" data-asset-detail-target="tabBtn" data-tab="notes"
              data-action="click->asset-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Notes
      </button>
      <button type="button" data-asset-detail-target="tabBtn" data-tab="documents"
              data-action="click->asset-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Documents
      </button>
    </nav>
  </div>

  <%# ===== Overview Tab Panel ===== %>
  <div data-asset-detail-target="tabPanel" data-tab="overview" class="mt-6">
    <%# View Section %>
    <div data-asset-detail-target="viewSection"
         class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div data-asset-detail-target="overviewContent">
        <p class="text-sm text-gray-400 dark:text-gray-500">Loading...</p>
      </div>
    </div>

    <%# Edit Section (hidden by default) %>
    <div data-asset-detail-target="editSection"
         class="hidden bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Edit Asset</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Asset Name <span class="text-red-500">*</span></label>
          <input type="text" data-asset-detail-target="editName" maxlength="80"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Type <span class="text-red-500">*</span></label>
          <select data-asset-detail-target="editType"
                  class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="">Select type...</option>
          </select>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Purchase Date</label>
            <input type="date" data-asset-detail-target="editPurchaseDate"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Purchase Price</label>
            <input type="number" step="0.01" min="0" data-asset-detail-target="editPurchasePrice"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                   placeholder="0.00">
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Current Value <span class="text-red-500">*</span></label>
          <input type="number" step="0.01" min="0" data-asset-detail-target="editCurrentValue"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                 placeholder="0.00">
        </div>
        <div class="flex items-center justify-between">
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Include in Net Worth</label>
          <div data-asset-detail-target="editNetWorth"></div>
        </div>
        <p class="text-sm text-red-600 dark:text-red-400 hidden" data-asset-detail-target="editError"></p>
      </div>
      <div class="flex justify-end space-x-3 mt-6">
        <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->asset-detail#cancelEdit">Cancel</button>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->asset-detail#saveEdit">Save</button>
      </div>
    </div>
  </div>

  <%# ===== Valuation History Tab Panel ===== %>
  <div data-asset-detail-target="tabPanel" data-tab="valuations" class="hidden mt-6">
    <%# Valuation Trend Chart (rendered by JS) %>
    <div data-asset-detail-target="valChart" class="mb-4"></div>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Value</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Source</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody data-asset-detail-target="valTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr><td colspan="4" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Select this tab to load valuations.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ===== Notes Tab Panel ===== %>
  <div data-asset-detail-target="tabPanel" data-tab="notes" class="hidden mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 max-w-2xl mx-auto">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Notes</label>
      <textarea data-asset-detail-target="notesArea"
                data-action="input->asset-detail#notesChanged"
                rows="8" maxlength="1000"
                class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 resize-y"
                placeholder="Add notes about this asset..."><%= @asset.notes %></textarea>
      <div class="flex items-center justify-end space-x-3 mt-3">
        <span class="text-xs text-gray-400 dark:text-gray-500" data-asset-detail-target="notesStatus"></span>
        <button type="button" data-asset-detail-target="notesSaveBtn"
                data-action="click->asset-detail#saveNotes"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition opacity-50"
                disabled>
          Save Notes
        </button>
      </div>
    </div>
  </div>

  <%# ===== Documents Tab Panel (scaffold) ===== %>
  <div data-asset-detail-target="tabPanel" data-tab="documents" class="hidden mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
      <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
      <h3 class="mt-3 text-sm font-medium text-gray-900 dark:text-white">Documents</h3>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Document management will be available in a future update.</p>
    </div>
  </div>

  <%# ===== Add Valuation Modal ===== %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50" data-role="val-modal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Add Valuation</h3>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date <span class="text-red-500">*</span></label>
          <input type="date" data-role="val-date"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Value <span class="text-red-500">*</span></label>
          <input type="number" step="0.01" min="0" data-role="val-value"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                 placeholder="0.00">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Source</label>
          <select data-role="val-source"
                  class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="manual">Manual</option>
            <option value="appraisal">Appraisal</option>
            <option value="system">System</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <input type="text" data-role="val-notes" maxlength="500"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="Optional notes">
        </div>
        <p class="text-sm text-red-600 dark:text-red-400 hidden" data-asset-detail-target="valError"></p>
      </div>
      <div class="flex justify-end space-x-3 mt-6">
        <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->asset-detail#cancelValuation">Cancel</button>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->asset-detail#saveValuation">Save</button>
      </div>
    </div>
  </div>
</div>
