<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="admin-audit-logs"
     data-admin-audit-logs-api-url-value="<%= api_admin_audit_logs_path %>"
     data-admin-audit-logs-csrf-token-value="<%= form_authenticity_token %>">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Audit Logs</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Assets, Investments & Financing audit trail</p>
      </div>
      <div class="text-sm text-gray-500 dark:text-gray-400" data-admin-audit-logs-target="totalCount"></div>
    </div>
  </div>

  <%# Filters %>
  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg p-4 mb-4 ring-1 ring-gray-200 dark:ring-gray-700">
    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 mb-1">Entity Type</label>
        <select data-admin-audit-logs-target="entityTypeFilter"
                class="rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm px-3 py-2">
          <option value="">All</option>
          <option value="Asset">Asset</option>
          <option value="AssetType">AssetType</option>
          <option value="InvestmentHolding">InvestmentHolding</option>
          <option value="InvestmentTransaction">InvestmentTransaction</option>
          <option value="FinancingInstrument">FinancingInstrument</option>
          <option value="FinancingPayment">FinancingPayment</option>
        </select>
      </div>
      <div>
        <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 mb-1">Action</label>
        <select data-admin-audit-logs-target="actionTypeFilter"
                class="rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm px-3 py-2">
          <option value="">All</option>
          <option value="CREATE">CREATE</option>
          <option value="UPDATE">UPDATE</option>
          <option value="DELETE">DELETE</option>
          <option value="RECALCULATION">RECALCULATION</option>
        </select>
      </div>
      <div>
        <button type="button"
                class="inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-brand-600 hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition"
                data-action="click->admin-audit-logs#applyFilters">
          Filter
        </button>
      </div>
    </div>
  </div>

  <%# Table %>
  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-44">Time</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-48">Entity</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-32">Action</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Changes</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700" data-admin-audit-logs-target="tableBody">
        <tr>
          <td colspan="4" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# Pagination %>
  <div class="mt-4 flex justify-center gap-1" data-admin-audit-logs-target="pagination"></div>
</div>
