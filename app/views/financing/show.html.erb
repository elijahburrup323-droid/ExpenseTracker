<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="financing-detail"
     data-financing-detail-instrument-id-value="<%= @instrument.id %>"
     data-financing-detail-payments-url-value="<%= api_financing_instrument_financing_payments_path(@instrument) %>"
     data-financing-detail-schedule-url-value="<%= api_financing_instrument_amortization_schedule_path(@instrument) %>"
     data-financing-detail-generate-url-value="<%= generate_api_financing_instrument_amortization_schedule_path(@instrument) %>"
     data-financing-detail-simulate-url-value="<%= simulate_payoff_api_financing_instrument_amortization_schedule_path(@instrument) %>"
     data-financing-detail-reconcile-url-value="<%= reconcile_api_financing_instrument_amortization_schedule_path(@instrument) %>"
     data-financing-detail-instrument-url-value="<%= api_financing_instrument_path(@instrument) %>"
     data-financing-detail-list-url-value="<%= financing_loans_notes_path %>"
     data-financing-detail-csrf-token-value="<%= form_authenticity_token %>">

  <%# ===== Page Header (sticky) ===== %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-center space-x-3 mb-1">
          <a href="<%= financing_loans_notes_path %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white" data-financing-detail-target="instrumentName"><%= @instrument.name %></h1>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @instrument.payable? ? 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400' : 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400' %>">
            <%= @instrument.instrument_type %>
          </span>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 ml-8">
          <%= @instrument.instrument_subtype&.titleize&.gsub('_', ' ') %>
          <span class="mx-1">&middot;</span>
          <span data-financing-detail-target="currentPrincipal"><%= number_to_currency(@instrument.current_principal) %></span> remaining
        </p>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button"
                data-action="click->financing-detail#openAddPayment"
                class="inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-lg text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 transition shadow-sm">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Record Payment
        </button>
      </div>
    </div>
  </div>

  <%# ===== Summary Metrics ===== %>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Original Principal</p>
      <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@instrument.original_principal) %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Current Balance</p>
      <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-white tabular-nums" data-financing-detail-target="balanceMetric"><%= number_to_currency(@instrument.current_principal) %></p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interest Rate</p>
      <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-white tabular-nums"><%= @instrument.interest_rate %>%</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Monthly Payment</p>
      <p class="mt-1 text-lg font-semibold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@instrument.monthly_payment || 0) %></p>
    </div>
  </div>

  <%# ===== Tab Navigation ===== %>
  <div class="border-b border-gray-200 dark:border-gray-700">
    <nav class="flex space-x-6 -mb-px" aria-label="Tabs">
      <button type="button" data-financing-detail-target="tabBtn" data-tab="schedule"
              data-action="click->financing-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-brand-600 text-brand-600 dark:border-brand-400 dark:text-brand-400 transition">
        Amortization Schedule
      </button>
      <button type="button" data-financing-detail-target="tabBtn" data-tab="payments"
              data-action="click->financing-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Payment History
      </button>
      <button type="button" data-financing-detail-target="tabBtn" data-tab="simulation"
              data-action="click->financing-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Payoff Simulation
      </button>
    </nav>
  </div>

  <%# ===== Amortization Schedule Tab ===== %>
  <div data-financing-detail-target="tabPanel" data-tab="schedule" class="mt-6">
    <div class="flex items-center justify-between mb-4">
      <div>
        <p class="text-sm text-gray-500 dark:text-gray-400" data-financing-detail-target="scheduleSummary">Loading schedule...</p>
      </div>
      <button type="button"
              data-action="click->financing-detail#generateSchedule"
              data-financing-detail-target="generateBtn"
              class="inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-brand-600 hover:bg-brand-700 transition">
        <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        Generate Schedule
      </button>
    </div>

    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">#</th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Due Date</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Beginning Bal.</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Payment</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interest</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Principal</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Ending Bal.</th>
            </tr>
          </thead>
          <tbody data-financing-detail-target="scheduleBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr><td colspan="7" class="px-4 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
      <%# Pagination %>
      <div data-financing-detail-target="schedulePagination" class="hidden border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/30 px-4 py-3 flex items-center justify-between">
      </div>
    </div>
  </div>

  <%# ===== Payment History Tab ===== %>
  <div data-financing-detail-target="tabPanel" data-tab="payments" class="hidden mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">#</th>
              <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interest</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Principal</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Extra Princ.</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Balance After</th>
              <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody data-financing-detail-target="paymentsBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr><td colspan="8" class="px-4 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Select this tab to load payments.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ===== Payoff Simulation Tab ===== %>
  <div data-financing-detail-target="tabPanel" data-tab="simulation" class="hidden mt-6">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <%# Input Panel %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Simulation Inputs</h3>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Extra Monthly Payment</label>
            <input type="number" step="0.01" min="0" data-financing-detail-target="simExtraMonthly"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                   placeholder="0.00" value="0">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">One-Time Lump Sum</label>
            <input type="number" step="0.01" min="0" data-financing-detail-target="simLumpSum"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                   placeholder="0.00" value="0">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Lump Sum Applied at Payment #</label>
            <input type="number" step="1" min="1" data-financing-detail-target="simLumpPeriod"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                   placeholder="1" value="1">
          </div>
          <button type="button"
                  data-action="click->financing-detail#runSimulation"
                  class="w-full inline-flex items-center justify-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-brand-600 hover:bg-brand-700 transition">
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
            Run Simulation
          </button>
          <p class="text-xs text-gray-400 dark:text-gray-500">This is a preview only — nothing is saved.</p>
        </div>
      </div>

      <%# Results Panel %>
      <div class="lg:col-span-2">
        <div data-financing-detail-target="simResults" class="hidden">
          <%# Comparison Cards %>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
              <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Interest Saved</p>
              <p class="mt-1 text-xl font-bold text-green-600 dark:text-green-400 tabular-nums" data-financing-detail-target="simInterestSaved">$0.00</p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
              <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Months Saved</p>
              <p class="mt-1 text-xl font-bold text-green-600 dark:text-green-400 tabular-nums" data-financing-detail-target="simMonthsSaved">0</p>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4">
              <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">New Payoff Date</p>
              <p class="mt-1 text-xl font-bold text-gray-900 dark:text-white" data-financing-detail-target="simPayoffDate">—</p>
            </div>
          </div>

          <%# Comparison Table %>
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-700/30">
              <div class="flex items-center justify-between">
                <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300">Original vs. Accelerated</h4>
              </div>
            </div>
            <div class="p-4">
              <table class="min-w-full text-sm">
                <thead>
                  <tr>
                    <th class="text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase pb-2"></th>
                    <th class="text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase pb-2">Original</th>
                    <th class="text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase pb-2">Accelerated</th>
                  </tr>
                </thead>
                <tbody data-financing-detail-target="simComparisonBody" class="divide-y divide-gray-100 dark:divide-gray-700/50">
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <%# Placeholder before simulation %>
        <div data-financing-detail-target="simPlaceholder" class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 text-center">
          <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
          </svg>
          <h3 class="mt-3 text-sm font-medium text-gray-900 dark:text-white">Payoff Simulation</h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Enter extra payment amounts and run a simulation to see how you can pay off your loan faster.</p>
        </div>
      </div>
    </div>
  </div>

  <%# ===== Add Payment Modal ===== %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50" data-financing-detail-target="paymentModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-lg w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4" data-financing-detail-target="paymentModalTitle">Record Payment</h3>
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Date <span class="text-red-500">*</span></label>
            <input type="date" data-financing-detail-target="payDate"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Total Amount <span class="text-red-500">*</span></label>
            <input type="number" step="0.01" min="0.01" data-financing-detail-target="payAmount"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums"
                   placeholder="0.00">
          </div>
        </div>

        <%# Manual allocation toggle %>
        <div class="flex items-center">
          <input type="checkbox" data-financing-detail-target="payManualToggle"
                 data-action="change->financing-detail#toggleManualAllocation"
                 class="h-4 w-4 text-brand-600 focus:ring-brand-500 border-gray-300 dark:border-gray-600 rounded">
          <label class="ml-2 text-sm text-gray-700 dark:text-gray-300">Manual allocation breakdown</label>
        </div>

        <%# Auto allocation preview %>
        <div data-financing-detail-target="payAutoPreview" class="bg-gray-50 dark:bg-gray-700/30 rounded-lg p-3 text-sm">
          <p class="text-gray-500 dark:text-gray-400 mb-1">Automatic allocation: Interest → Principal → Extra Principal</p>
          <div data-financing-detail-target="payPreviewBreakdown" class="text-gray-700 dark:text-gray-300"></div>
        </div>

        <%# Manual allocation fields (hidden by default) %>
        <div data-financing-detail-target="payManualFields" class="hidden space-y-3">
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Interest</label>
              <input type="number" step="0.01" min="0" data-financing-detail-target="payInterest"
                     class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white tabular-nums" placeholder="0.00">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Principal</label>
              <input type="number" step="0.01" min="0" data-financing-detail-target="payPrincipal"
                     class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white tabular-nums" placeholder="0.00">
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Extra Principal</label>
              <input type="number" step="0.01" min="0" data-financing-detail-target="payExtraPrincipal"
                     class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white tabular-nums" placeholder="0.00">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Escrow</label>
              <input type="number" step="0.01" min="0" data-financing-detail-target="payEscrow"
                     class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white tabular-nums" placeholder="0.00">
            </div>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <input type="text" maxlength="500" data-financing-detail-target="payNotes"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white"
                 placeholder="Optional notes">
        </div>
        <p class="text-sm text-red-600 dark:text-red-400 hidden" data-financing-detail-target="payError"></p>
      </div>
      <div class="flex justify-end space-x-3 mt-6">
        <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->financing-detail#cancelPayment">Cancel</button>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->financing-detail#savePayment">Save Payment</button>
      </div>
    </div>
  </div>

  <%# ===== Delete Payment Confirmation Modal ===== %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50" data-financing-detail-target="deletePaymentModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-sm w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Delete Payment</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Are you sure? This will reverse the payment and recalculate the amortization schedule.</p>
      <div class="flex justify-end space-x-3">
        <button type="button" class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->financing-detail#cancelDeletePayment">Cancel</button>
        <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg shadow-sm transition"
                data-action="click->financing-detail#confirmDeletePayment">Delete</button>
      </div>
    </div>
  </div>
</div>
