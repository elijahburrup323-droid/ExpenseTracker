<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="financing-debts-loans"
     data-financing-debts-loans-api-url-value="<%= api_financing_instruments_path %>"
     data-financing-debts-loans-csrf-token-value="<%= form_authenticity_token %>">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex items-center space-x-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Debts & Loans</h1>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Track all debts, loans, and payment progress
            <span class="ml-2 text-xs text-gray-400 dark:text-gray-500"
                  data-financing-debts-loans-target="total"></span>
          </p>
        </div>
      </div>
      <div class="flex items-center space-x-2">
        <%# Debt Type filter dropdown %>
        <select data-financing-debts-loans-target="debtTypeFilter"
                data-action="change->financing-debts-loans#filterByDebtType"
                class="text-sm border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">All Types</option>
        </select>
        <button type="button"
                data-financing-debts-loans-target="addButton"
                data-action="click->financing-debts-loans#startAdding"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition"
                data-tutorial="add-instrument-btn">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Debt / Loan
        </button>
      </div>
    </div>
  </div>

  <%# Data Table %>
  <div class="mt-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden" data-tutorial="financing-table">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="name" data-action="click->financing-debts-loans#toggleSort">
              Name <span data-sort-icon="name" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="debt_type" data-action="click->financing-debts-loans#toggleSort">
              Debt Type <span data-sort-icon="debt_type" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="original_principal" data-action="click->financing-debts-loans#toggleSort">
              Original Amount <span data-sort-icon="original_principal" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="current_principal" data-action="click->financing-debts-loans#toggleSort">
              Current Balance <span data-sort-icon="current_principal" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Progress
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Last Activity
            </th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="status" data-action="click->financing-debts-loans#toggleSort">
              Status <span data-sort-icon="status" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="in_net_worth" data-action="click->financing-debts-loans#toggleSort">
              Net Worth <span data-sort-icon="in_net_worth" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody data-financing-debts-loans-target="tableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
          <tr><td colspan="9" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <%# ── Add / Edit Modal ─────────────────────────────────── %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50"
       data-financing-debts-loans-target="instrumentModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-2xl w-full mx-4 p-6 max-h-[90vh] overflow-y-auto">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4"
          data-financing-debts-loans-target="modalTitle">Add Debt / Loan</h3>

      <div class="space-y-4">
        <%# Name %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name <span class="text-red-500">*</span></label>
          <input type="text"
                 data-financing-debts-loans-target="modalName"
                 maxlength="80"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="e.g. Home Mortgage">
        </div>

        <%# Direction + Debt Type + Loan Type %>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Direction <span class="text-red-500">*</span></label>
            <select data-financing-debts-loans-target="modalInstrumentType"
                    class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
              <option value="">Select direction...</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Debt Type</label>
            <select data-financing-debts-loans-target="modalDebtType"
                    class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
              <option value="">Select type...</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Loan Subtype</label>
            <select data-financing-debts-loans-target="modalSubtype"
                    class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
              <option value="">Select subtype...</option>
            </select>
          </div>
        </div>

        <%# Original + Current Principal %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Original Principal <span class="text-red-500">*</span></label>
            <input type="number" step="0.01" min="0.01"
                   data-financing-debts-loans-target="modalOriginalPrincipal"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="250000.00">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Current Principal</label>
            <input type="number" step="0.01" min="0"
                   data-financing-debts-loans-target="modalCurrentPrincipal"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="Defaults to Original Principal">
          </div>
        </div>

        <%# Interest Rate + Term %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Interest Rate (%) <span class="text-red-500">*</span></label>
            <input type="number" step="0.01" min="0"
                   data-financing-debts-loans-target="modalInterestRate"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="6.50">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Term (months) <span class="text-red-500">*</span></label>
            <input type="number" step="1" min="1" max="480"
                   data-financing-debts-loans-target="modalTermMonths"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="360">
          </div>
        </div>

        <%# Start Date + Maturity Date %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Start Date <span class="text-red-500">*</span></label>
            <input type="date"
                   data-financing-debts-loans-target="modalStartDate"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Maturity Date</label>
            <input type="date"
                   data-financing-debts-loans-target="modalMaturityDate"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          </div>
        </div>

        <%# Payment Frequency + Monthly Payment %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Frequency</label>
            <select data-financing-debts-loans-target="modalPaymentFrequency"
                    class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Amount</label>
            <input type="number" step="0.01" min="0"
                   data-financing-debts-loans-target="modalMonthlyPayment"
                   class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="1,200.00">
          </div>
        </div>

        <%# Lender / Borrower %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Lender / Borrower</label>
          <input type="text"
                 data-financing-debts-loans-target="modalLenderOrBorrower"
                 maxlength="120"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="e.g. Wells Fargo">
        </div>

        <%# Description %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
          <input type="text"
                 data-financing-debts-loans-target="modalDescription"
                 maxlength="255"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="Optional description">
        </div>

        <%# Include in Net Worth %>
        <div class="flex items-center justify-between">
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Include in Net Worth</label>
          <div data-financing-debts-loans-target="modalNetWorth"></div>
        </div>

        <%# Notes %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <textarea data-financing-debts-loans-target="modalNotes"
                    rows="2"
                    class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                    placeholder="Optional notes"></textarea>
        </div>

        <%# Error message %>
        <p class="text-sm text-red-600 dark:text-red-400 hidden"
           data-financing-debts-loans-target="modalError"></p>
      </div>

      <div class="flex justify-end space-x-3 mt-6">
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->financing-debts-loans#cancelModal">Cancel</button>
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->financing-debts-loans#saveModal">Save</button>
      </div>
    </div>
  </div>

  <%# ── Delete Confirmation Modal ─────────────────────────── %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50"
       data-financing-debts-loans-target="deleteModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Delete Debt / Loan</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        Are you sure you want to delete <strong class="text-gray-900 dark:text-white" data-financing-debts-loans-target="deleteModalName"></strong>?
        This action cannot be undone.
      </p>
      <div class="flex justify-end space-x-3">
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->financing-debts-loans#cancelDelete">Cancel</button>
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg shadow-sm transition"
                data-action="click->financing-debts-loans#executeDelete">Delete</button>
      </div>
    </div>
  </div>

  <%# ── Quick Payment Modal ─────────────────────────── %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50"
       data-financing-debts-loans-target="quickPaymentModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Record Payment</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">
        Recording payment for <strong class="text-gray-900 dark:text-white" data-financing-debts-loans-target="quickPaymentName"></strong>
      </p>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Amount <span class="text-red-500">*</span></label>
          <input type="number" step="0.01" min="0.01"
                 data-financing-debts-loans-target="quickPaymentAmount"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="500.00">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Payment Date <span class="text-red-500">*</span></label>
          <input type="date"
                 data-financing-debts-loans-target="quickPaymentDate"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <input type="text"
                 data-financing-debts-loans-target="quickPaymentNotes"
                 maxlength="500"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="Optional notes">
        </div>
        <p class="text-sm text-red-600 dark:text-red-400 hidden"
           data-financing-debts-loans-target="quickPaymentError"></p>
      </div>
      <div class="flex justify-end space-x-3 mt-6">
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->financing-debts-loans#cancelQuickPayment">Cancel</button>
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->financing-debts-loans#saveQuickPayment">Record Payment</button>
      </div>
    </div>
  </div>
</div>
