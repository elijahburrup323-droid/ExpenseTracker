<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6"
     data-controller="reports"
     data-reports-reorder-url-value="<%= api_reports_reorder_path %>">

  <%# Page header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-baseline space-x-3">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Reports</h1>
          <% if @tutorial_available %>
            <a href="<%= request.path %>?start_tutorial=1" class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-brand-600 bg-brand-50 rounded-lg hover:bg-brand-100 transition">
              <svg class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
              Tour
            </a>
          <% end %>
        </div>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">View financial summaries and historical insights for the selected month.</p>
      </div>
      <div class="flex items-center space-x-2 text-sm font-medium text-gray-700 dark:text-gray-300" data-tutorial="reports-period">
        <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span><%= @month_label %></span>
      </div>
    </div>
  </div>

  <%# Report Cards Grid %>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6" data-reports-target="cardsGrid" data-tutorial="reports-grid">
    <% @slots.each do |slot| %>
      <% defn = slot.definition %>
      <% next unless defn&.is_active %>
      <div class="group bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 hover:shadow-md hover:border-brand-300 dark:hover:border-brand-600 transition-all cursor-pointer flex flex-col"
           data-reports-target="cardWrapper"
           data-slot-number="<%= slot.slot_number %>"
           data-report-key="<%= slot.report_key %>">

        <%# Card Header: Icon + Category badge %>
        <div class="flex items-start justify-between p-5 pb-3">
          <div class="flex items-center space-x-3">
            <div class="flex items-center justify-center h-10 w-10 rounded-lg bg-brand-50 dark:bg-brand-900/30 text-brand-600 dark:text-brand-400"
                 data-icon-key="<%= defn.icon_key %>">
            </div>
          </div>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300 whitespace-nowrap">
            <%= defn.category %>
          </span>
        </div>

        <%# Card Body: Title + Description %>
        <div class="px-5 pb-5 flex-1 flex flex-col">
          <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
            <%= defn.title %>
          </h3>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400 line-clamp-2">
            <%= defn.description %>
          </p>
          <div class="mt-auto pt-3">
            <% if defn.route_path.present? %>
              <%= link_to "#{ActionController::Base.relative_url_root}#{defn.route_path}", class: "inline-flex items-center text-xs font-medium text-brand-600 dark:text-brand-400 hover:underline" do %>
                View Report
                <svg class="ml-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              <% end %>
            <% else %>
              <span class="inline-flex items-center text-xs font-medium text-gray-400 dark:text-gray-500">
                Coming Soon
                <svg class="ml-1 h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            <% end %>
          </div>
        </div>

      </div>
    <% end %>
  </div>
</div>
