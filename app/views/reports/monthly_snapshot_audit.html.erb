<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="snapshot-audit"
     data-snapshot-audit-api-url-value="<%= api_reports_monthly_snapshot_audit_path %>"
     data-snapshot-audit-accounts-url-value="<%= api_accounts_path %>"
     data-snapshot-audit-year-value="<%= @open_month.current_year %>"
     data-snapshot-audit-month-value="<%= @open_month.current_month %>">

  <%# Report Options Modal %>
  <div data-snapshot-audit-target="optionsModal"
       class="fixed inset-0 z-50 overflow-y-auto">
    <div class="flex min-h-full items-center justify-center p-4">
      <div class="fixed inset-0 bg-black/50 transition-opacity"></div>
      <div class="relative bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-md p-6 ring-1 ring-gray-200 dark:ring-gray-700">
        <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">Monthly Snapshot Audit</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-5">Compare snapshot balances against transaction detail.</p>

        <%# Account Selection %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account</label>
          <select data-snapshot-audit-target="accountSelect"
                  class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-white px-3 py-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="">All Accounts</option>
          </select>
        </div>

        <%# Date Range %>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date Range</label>
          <div class="grid grid-cols-2 gap-3">
            <div>
              <span class="block text-xs text-gray-500 dark:text-gray-400 mb-1">Start</span>
              <div class="flex gap-1">
                <select data-snapshot-audit-target="startMonthSelect"
                        class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-white px-2 py-2 focus:ring-brand-500 focus:border-brand-500">
                </select>
                <select data-snapshot-audit-target="startYearSelect"
                        class="w-20 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-white px-2 py-2 focus:ring-brand-500 focus:border-brand-500">
                </select>
              </div>
            </div>
            <div>
              <span class="block text-xs text-gray-500 dark:text-gray-400 mb-1">End</span>
              <div class="flex gap-1">
                <select data-snapshot-audit-target="endMonthSelect"
                        class="flex-1 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-white px-2 py-2 focus:ring-brand-500 focus:border-brand-500">
                </select>
                <select data-snapshot-audit-target="endYearSelect"
                        class="w-20 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-white px-2 py-2 focus:ring-brand-500 focus:border-brand-500">
                </select>
              </div>
            </div>
          </div>
        </div>

        <div class="flex justify-end space-x-3 mt-6">
          <a href="<%= reports_path %>"
             class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">Back</a>
          <button type="button"
                  data-action="click->snapshot-audit#runReport"
                  class="px-4 py-2 text-sm font-medium text-white bg-brand-600 hover:bg-brand-700 rounded-lg shadow-sm transition">Run Report</button>
        </div>
      </div>
    </div>
  </div>

  <%# Report Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm hidden"
       data-snapshot-audit-target="reportHeader">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Monthly Snapshot Audit</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400" data-snapshot-audit-target="subtitle"></p>
      </div>
      <button type="button"
              data-action="click->snapshot-audit#showOptions"
              class="inline-flex items-center px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition">
        <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 11-3 0m3 0a1.5 1.5 0 10-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m-9.75 0h9.75"/></svg>
        Options
      </button>
    </div>
  </div>

  <%# Report Content %>
  <div class="hidden" data-snapshot-audit-target="reportContent">
    <div data-snapshot-audit-target="reportBody" class="space-y-6"></div>
  </div>
</div>
