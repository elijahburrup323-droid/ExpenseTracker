<%# Step 4: Summary — You're all set %>
<%
  profile = user.onboarding_profile
  persona = profile&.persona || "exploring"
  block_keys = UserOnboardingProfile::PERSONA_BLOCKS.fetch(persona, UserOnboardingProfile::PERSONA_BLOCKS["exploring"])
  feature_blocks = FeatureBlock.where(key: block_keys).order(:sort_order)
  core_blocks = FeatureBlock.core.where.not(key: block_keys).order(:sort_order)
  all_blocks = (feature_blocks + core_blocks).uniq(&:id)
%>

<div class="text-center mb-8">
  <%# Green checkmark celebration icon %>
  <div class="mx-auto w-16 h-16 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center mb-4">
    <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
  </div>
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">
    You're all set!
  </h2>
  <p class="text-gray-500 dark:text-gray-400">
    Here's what we've activated for you based on your choices.
  </p>
</div>

<%# Activated features list %>
<div class="mb-6 space-y-2">
  <% all_blocks.each do |block| %>
    <div class="flex items-center space-x-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-700/50">
      <svg class="w-5 h-5 text-green-500 dark:text-green-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
      </svg>
      <div class="min-w-0">
        <span class="text-sm font-medium text-gray-900 dark:text-white"><%= block.display_name %></span>
        <% if block.tagline.present? %>
          <span class="text-sm text-gray-400 dark:text-gray-500"> &mdash; <%= block.tagline %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<%# Note about Feature Store %>
<div class="mb-8 p-4 rounded-lg bg-brand-50 dark:bg-brand-900/20 border border-brand-200 dark:border-brand-800/50">
  <div class="flex items-start space-x-3">
    <svg class="w-5 h-5 text-brand-600 dark:text-brand-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
    </svg>
    <p class="text-sm text-brand-700 dark:text-brand-300">
      Want more? Visit the <strong>Feature Store</strong> any time to discover and activate additional features like reports, smart import, reconciliation, and more.
    </p>
  </div>
</div>

<%= form_tag(onboarding_path, method: :patch) do %>
  <%= hidden_field_tag :step, 4 %>

  <button type="submit"
          class="w-full inline-flex items-center justify-center px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-lg shadow-sm transition focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 dark:focus:ring-offset-gray-800 text-base">
    Start Using MyBudgetHQ
    <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
    </svg>
  </button>
<% end %>
