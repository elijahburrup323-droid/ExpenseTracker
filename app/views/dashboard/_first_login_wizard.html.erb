<%# First Login Wizard — shown when user has zero accounts %>
<%
  om = OpenMonthMaster.for_user(current_user)
  open_month_date = Date.new(om.current_year, om.current_month, 1).strftime("%Y-%m-%d")
%>
<div data-controller="first-login-wizard"
     data-first-login-wizard-create-url-value="<%= api_accounts_path %>"
     data-first-login-wizard-csrf-token-value="<%= form_authenticity_token %>"
     data-first-login-wizard-open-month-value="<%= open_month_date %>">

  <%# Overlay — blocks all interaction behind wizard %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm"
       data-first-login-wizard-target="overlay">

    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-2xl border border-gray-200 dark:border-gray-700 w-full max-w-lg mx-4 p-8">

      <%# ===== STEP 1: Welcome ===== %>
      <div data-first-login-wizard-target="step1">
        <div class="text-center mb-6">
          <div class="mx-auto w-16 h-16 bg-brand-100 dark:bg-brand-900/30 rounded-full flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/>
            </svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Welcome to MyBudgetHQ!</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
            Before you can budget, we need to know where your money is.
            Let's add your checking, savings, or cash accounts and enter their current balances.
          </p>
        </div>
        <button type="button"
                data-action="click->first-login-wizard#toStep2"
                class="w-full py-3 px-4 bg-brand-600 hover:bg-brand-700 text-white font-medium rounded-lg transition text-sm">
          Let's Get Started
        </button>
      </div>

      <%# ===== STEP 2: Select Account Type ===== %>
      <div class="hidden" data-first-login-wizard-target="step2">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-1">What type of account?</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Choose the type of account you'd like to add first.</p>

        <div class="space-y-3">
          <button type="button"
                  data-first-login-wizard-target="typeBtn"
                  data-action="click->first-login-wizard#selectType"
                  data-type-name="Checking"
                  data-type-id="4"
                  class="w-full flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:border-brand-300 dark:hover:border-brand-600 transition cursor-pointer text-left">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 dark:text-white">Checking</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Your everyday spending account</div>
            </div>
          </button>

          <button type="button"
                  data-first-login-wizard-target="typeBtn"
                  data-action="click->first-login-wizard#selectType"
                  data-type-name="Savings"
                  data-type-id="13"
                  class="w-full flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:border-brand-300 dark:hover:border-brand-600 transition cursor-pointer text-left">
            <div class="w-10 h-10 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 dark:text-white">Savings</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Your rainy-day or savings fund</div>
            </div>
          </button>

          <button type="button"
                  data-first-login-wizard-target="typeBtn"
                  data-action="click->first-login-wizard#selectType"
                  data-type-name="Cash Card"
                  data-type-id="3"
                  class="w-full flex items-center p-4 border-2 border-gray-200 dark:border-gray-700 rounded-xl hover:border-brand-300 dark:hover:border-brand-600 transition cursor-pointer text-left">
            <div class="w-10 h-10 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center mr-4 flex-shrink-0">
              <svg class="w-5 h-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-gray-900 dark:text-white">Cash</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Physical cash or cash app balance</div>
            </div>
          </button>
        </div>
      </div>

      <%# ===== STEP 3: Enter Account Details ===== %>
      <div class="hidden" data-first-login-wizard-target="step3">
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-1">Account Details</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">Enter a name and your current balance.</p>

        <form data-action="submit->first-login-wizard#createAccount" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account Name <span class="text-red-500">*</span></label>
            <input type="text"
                   data-first-login-wizard-target="accountName"
                   class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="e.g., Chase Checking"
                   required>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Starting Balance <span class="text-red-500">*</span></label>
            <div class="relative">
              <span class="absolute left-3 top-2.5 text-gray-400 text-sm">$</span>
              <input type="number"
                     step="0.01"
                     data-first-login-wizard-target="startingBalance"
                     class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white pl-7 pr-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                     placeholder="0.00"
                     required>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Note <span class="text-gray-400 font-normal">(optional)</span></label>
            <input type="text"
                   data-first-login-wizard-target="accountNote"
                   class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white px-3 py-2 text-sm focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                   placeholder="e.g., Primary account">
          </div>

          <%# Error display %>
          <div class="hidden text-sm text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/20 rounded-lg p-3"
               data-first-login-wizard-target="createError"></div>

          <div class="flex space-x-3 pt-2">
            <button type="button"
                    data-action="click->first-login-wizard#addAnother"
                    class="flex-1 py-2.5 px-4 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 font-medium rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-700 transition">
              Back
            </button>
            <button type="submit"
                    data-first-login-wizard-target="createBtn"
                    class="flex-1 py-2.5 px-4 bg-brand-600 hover:bg-brand-700 text-white font-medium rounded-lg text-sm transition">
              Create Account
            </button>
          </div>
        </form>
      </div>

      <%# ===== STEP 4: Post-Creation Choice ===== %>
      <div class="hidden" data-first-login-wizard-target="step4">
        <div class="text-center mb-6">
          <div class="mx-auto w-16 h-16 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-1">Account Created!</h2>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <span data-first-login-wizard-target="createdName" class="font-semibold"></span>
            with a balance of
            <span data-first-login-wizard-target="createdBalance" class="font-semibold text-green-600 dark:text-green-400"></span>
          </p>
        </div>

        <div class="space-y-3">
          <button type="button"
                  data-action="click->first-login-wizard#addAnother"
                  class="w-full py-3 px-4 border-2 border-brand-200 dark:border-brand-700 text-brand-700 dark:text-brand-300 font-medium rounded-lg text-sm hover:bg-brand-50 dark:hover:bg-brand-900/20 transition">
            Add Another Account
          </button>
          <button type="button"
                  data-action="click->first-login-wizard#finishSetup"
                  class="w-full py-3 px-4 bg-brand-600 hover:bg-brand-700 text-white font-medium rounded-lg text-sm transition">
            Finish Setup
          </button>
        </div>
      </div>

    </div>
  </div>
</div>
