<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE: Calm text summary === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
    </div>
    <%# === Calm Snapshot: Net Worth value + change arrow + sparkline === %>
    <div class="flex-1 min-h-0 overflow-y-auto flex flex-col items-center pt-5" data-role="card-content">
      <span class="number-primary text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@net_worth) %></span>
      <% if @net_worth_snapshots.size >= 2 %>
        <% if @net_worth_change >= 0 %>
          <span class="text-sm text-emerald-600 dark:text-emerald-400 mt-1 tabular-nums font-medium">
            &#9650; +<%= number_to_currency(@net_worth_change) %>
          </span>
        <% else %>
          <span class="text-sm text-red-500 dark:text-red-400 mt-1 tabular-nums font-medium">
            &#9660; <%= number_to_currency(@net_worth_change) %>
          </span>
        <% end %>
      <% end %>
      <%# Inline sparkline — last 4 net worth snapshots %>
      <% spark_snaps = @net_worth_snapshots.last(4) %>
      <% if spark_snaps.size >= 2 %>
        <%
          spark_amounts = spark_snaps.map { |s| s.amount.to_f }
          spark_min = spark_amounts.min
          spark_max = spark_amounts.max
          spark_range = spark_max - spark_min
          spark_range = 1 if spark_range == 0
          spark_w = 120
          spark_h = 32
          spark_pad = 4
          spark_points = spark_snaps.each_with_index.map do |s, i|
            sx = spark_pad + (i.to_f / (spark_snaps.size - 1)) * (spark_w - spark_pad * 2)
            sy = spark_pad + (spark_h - spark_pad * 2) - ((s.amount.to_f - spark_min) / spark_range * (spark_h - spark_pad * 2))
            [sx.round(1), sy.round(1)]
          end
          spark_polyline = spark_points.map { |x, y| "#{x},#{y}" }.join(" ")
        %>
        <svg class="mt-2" width="120" height="32" viewBox="0 0 120 32" fill="none">
          <polyline points="<%= spark_polyline %>" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <% spark_points.each_with_index do |(x, y), i| %>
            <% if i == spark_points.size - 1 %>
              <circle cx="<%= x %>" cy="<%= y %>" r="3.5" fill="#3b82f6"/>
            <% else %>
              <circle cx="<%= x %>" cy="<%= y %>" r="2" fill="#93c5fd"/>
            <% end %>
          <% end %>
        </svg>
      <% end %>
    </div>


    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View net worth breakdown">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Net Worth Breakdown</span>
      </button>
    </div>
  </div>

  <%# === BACK SIDE: Net Worth Breakdown (Expanded — full chart + asset/liability columns + summary) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;"
       data-controller="net-worth-breakdown"
       data-net-worth-breakdown-url-value="<%= breakdown_api_net_worth_snapshots_path %>">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center space-x-2">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Net Worth Breakdown</h2>
        <span class="text-[10px] text-gray-400 dark:text-gray-500" data-net-worth-breakdown-target="selectedLabel"></span>
      </div>
    </div>

    <%# === SECTION 1: Net Worth History Chart (FIXED — does not scroll) === %>
    <div class="flex-shrink-0" data-role="back-content">
      <% snapshots = @net_worth_snapshots %>
      <% if snapshots.size >= 2 %>
        <%
          amounts = snapshots.map { |s| s.amount.to_f }
          min_val = amounts.min
          max_val = amounts.max
          range = max_val - min_val
          range = 1 if range == 0
          padding = 5
          chart_h = 50
          chart_w = 190

          points = snapshots.each_with_index.map do |s, i|
            x = padding + (i.to_f / (snapshots.size - 1)) * chart_w
            y = padding + chart_h - ((s.amount.to_f - min_val) / range * chart_h)
            [x.round(1), y.round(1)]
          end

          polyline_str = points.map { |x, y| "#{x},#{y}" }.join(" ")
          area_path = "M#{points.first[0]},#{points.first[1]} " +
                      points[1..].map { |x, y| "L#{x},#{y}" }.join(" ") +
                      " L#{points.last[0]},#{padding + chart_h} L#{points.first[0]},#{padding + chart_h} Z"
        %>
        <div class="w-full h-16 relative mb-0.5" data-controller="chart-tooltip" data-chart-tooltip-target="chart">
          <svg viewBox="0 0 200 60" class="w-full h-full" preserveAspectRatio="none">
            <defs>
              <linearGradient id="netWorthGrad" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#a855f7" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#a855f7" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <path d="<%= area_path %>" fill="url(#netWorthGrad)"/>
            <polyline points="<%= polyline_str %>"
                      fill="none" stroke="#a855f7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <% snapshots.each_with_index do |s, i| %>
              <circle cx="<%= points[i][0] %>" cy="<%= points[i][1] %>" r="6" fill="transparent"
                      data-month="<%= s.snapshot_date.strftime('%b %Y') %>"
                      data-amount="<%= s.amount.to_f %>"
                      data-year="<%= s.snapshot_date.year %>"
                      data-nw-month="<%= s.snapshot_date.month %>"
                      data-label="<%= s.snapshot_date.strftime('%b %Y') %>"
                      data-action="pointerdown->chart-tooltip#show pointerdown->net-worth-breakdown#selectMonth"
                      class="cursor-pointer" style="pointer-events: all;"/>
              <circle cx="<%= points[i][0] %>" cy="<%= points[i][1] %>" r="3" fill="#a855f7" data-role="chart-dot"
                      data-year="<%= s.snapshot_date.year %>" data-month="<%= s.snapshot_date.month %>"
                      style="pointer-events: none;"/>
            <% end %>
          </svg>
          <div data-chart-tooltip-target="tooltip"
               class="hidden absolute z-10 px-2.5 py-1.5 text-[11px] text-center rounded-lg shadow-lg bg-gray-900 dark:bg-gray-700 text-white whitespace-nowrap"
               style="pointer-events: none;"></div>
        </div>
        <%# Month labels with values under each dot %>
        <div class="flex justify-between text-center mb-3">
          <% snapshots.each do |s| %>
            <div class="flex flex-col items-center">
              <span class="text-[10px] text-gray-400 dark:text-gray-500"><%= s.snapshot_date.strftime("%b") %></span>
              <span class="text-[9px] font-medium text-gray-500 dark:text-gray-400 tabular-nums"><%= number_to_currency(s.amount.to_f, precision: 0) %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="w-full py-3 flex items-center justify-center">
          <p class="text-xs text-gray-400 dark:text-gray-500"><%= snapshots.size == 0 ? "No history yet" : "Not enough data for chart." %></p>
        </div>
      <% end %>
    </div>

    <%# === SECTION 2: Asset / Liability Breakdown (SCROLLABLE middle) === %>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="back-content">
      <div class="grid grid-cols-2 gap-4" data-role="nw-breakdown">
        <%# Assets column %>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Assets</span>
            <span class="text-[10px] font-semibold text-gray-900 dark:text-white tabular-nums" data-net-worth-breakdown-target="assetTotal"><%= number_to_currency(@net_worth_assets) %></span>
          </div>
          <div class="space-y-0.5" data-net-worth-breakdown-target="assetList">
            <% if @nw_asset_items.any? %>
              <% @nw_asset_items.each do |item| %>
                <div class="flex items-center justify-between">
                  <span class="text-[11px] text-gray-600 dark:text-gray-400 truncate mr-1"><%= item[:name] %></span>
                  <span class="text-[11px] font-medium text-gray-900 dark:text-white tabular-nums flex-shrink-0"><%= number_to_currency(item[:value]) %></span>
                </div>
              <% end %>
            <% else %>
              <p class="text-[10px] text-gray-400 dark:text-gray-500">No assets.</p>
            <% end %>
          </div>
        </div>
        <%# Liabilities column %>
        <div>
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Liabilities</span>
            <span class="text-[10px] font-semibold text-red-500 dark:text-red-400 tabular-nums" data-net-worth-breakdown-target="liabilityTotal"><%= @net_worth_liabilities > 0 ? "-" : "" %><%= number_to_currency(@net_worth_liabilities) %></span>
          </div>
          <div class="space-y-0.5" data-net-worth-breakdown-target="liabilityList">
            <% if @nw_liability_items.any? %>
              <% @nw_liability_items.each do |item| %>
                <div class="flex items-center justify-between">
                  <span class="text-[11px] text-gray-600 dark:text-gray-400 truncate mr-1"><%= item[:name] %></span>
                  <span class="text-[11px] font-medium text-red-500 dark:text-red-400 tabular-nums flex-shrink-0">-<%= number_to_currency(item[:value]) %></span>
                </div>
              <% end %>
            <% else %>
              <p class="text-[10px] text-gray-400 dark:text-gray-500">No liabilities.</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# === SECTION 3: Large Net Worth Summary (FIXED — does not scroll) === %>
    <div class="flex-shrink-0 border-t border-gray-200 dark:border-gray-600 pt-2 text-center">
      <span class="text-[10px] font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Net Worth</span>
      <div class="text-xl font-bold tabular-nums mt-0.5 <%= @net_worth >= 0 ? 'text-emerald-600 dark:text-emerald-400' : 'text-red-500 dark:text-red-400' %>"
           data-net-worth-breakdown-target="netWorthValue">
        <%= number_to_currency(@net_worth) %>
      </div>
    </div>

    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to net worth chart">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Net Worth</span>
      </button>
    </div>
  </div>
</div>
