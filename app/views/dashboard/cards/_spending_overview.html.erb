<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Spending Overview</h2>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="card-content">
      <div class="flex flex-col flex-1 pt-5 space-y-6" style="font-variant-numeric: tabular-nums;">
        <%# === Spent This Month === %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500 dark:text-gray-400">Spent This Month</span>
          <span class="number-primary text-gray-800 dark:text-gray-100 tabular-nums"><%= number_to_currency(@spent_mtd, precision: 2) %></span>
        </div>

        <%# === Cash In Spending Accounts === %>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-500 dark:text-gray-400">Cash In Spending Accounts</span>
          <span class="number-primary text-gray-800 dark:text-gray-100 tabular-nums"><%= number_to_currency(@operating_balance, precision: 2) %></span>
        </div>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View details">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <button type="button" data-action="click->dashboard#toggleCardExpand"
              data-role="expand-btn"
              class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
              aria-label="Expand Spending Overview">
        <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
        </svg>
        <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
        </svg>
      </button>
    </div>
  </div>
  <%# === BACK SIDE (Details: Bills, Deposits, Cash Available) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Spending Details</h2>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="back-content">
      <% spent_total = @spent_mtd.to_f %>
      <% income_total = @current_month_income.to_f %>
      <div class="overflow-x-auto py-3">
        <div class="grid grid-cols-4 gap-4" style="font-variant-numeric: tabular-nums; min-width: 560px;">
          <%# === Column 1: By Category === %>
          <div class="flex flex-col min-w-0">
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 pb-1 border-b border-gray-200 dark:border-gray-600">By Category</p>
            <div class="flex-1 space-y-0.5">
              <% @spending_by_category.each do |cat| %>
                <div class="flex items-baseline justify-between gap-1">
                  <span class="text-[11px] text-gray-700 dark:text-gray-300 truncate"><%= cat[:name] %></span>
                  <span class="text-[11px] font-medium text-gray-800 dark:text-gray-200 whitespace-nowrap"><%= number_to_currency(cat[:amount]) %> <span class="text-[9px] text-gray-400 dark:text-gray-500"><%= cat[:pct] %>%</span></span>
                </div>
              <% end %>
            </div>
            <div class="border-t border-gray-200 dark:border-gray-600 mt-2 pt-1">
              <div class="flex items-center justify-between">
                <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200">Total</span>
                <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200"><%= number_to_currency(spent_total) %></span>
              </div>
            </div>
          </div>

          <%# === Column 2: By Spending Type === %>
          <div class="flex flex-col min-w-0">
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 pb-1 border-b border-gray-200 dark:border-gray-600">By Spending Type</p>
            <div class="flex-1 space-y-0.5">
              <% @spending_by_type.each do |tp| %>
                <div class="flex items-baseline justify-between gap-1">
                  <span class="text-[11px] text-gray-700 dark:text-gray-300 truncate"><%= tp[:name] %></span>
                  <span class="text-[11px] font-medium text-gray-800 dark:text-gray-200 whitespace-nowrap"><%= number_to_currency(tp[:amount]) %> <span class="text-[9px] text-gray-400 dark:text-gray-500"><%= tp[:pct] %>%</span></span>
                </div>
              <% end %>
            </div>
            <div class="border-t border-gray-200 dark:border-gray-600 mt-2 pt-1">
              <div class="flex items-center justify-between">
                <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200">Total</span>
                <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200"><%= number_to_currency(spent_total) %></span>
              </div>
            </div>
          </div>

          <%# === Column 3: By Tag === %>
          <div class="flex flex-col min-w-0">
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 pb-1 border-b border-gray-200 dark:border-gray-600">By Tag</p>
            <div class="flex-1 space-y-0.5">
              <% if @spending_by_tag.any? %>
                <% @spending_by_tag.each do |tag| %>
                  <div class="flex items-baseline justify-between gap-1">
                    <span class="text-[11px] text-gray-700 dark:text-gray-300 truncate"><%= tag[:name] %></span>
                    <span class="text-[11px] font-medium text-gray-800 dark:text-gray-200 whitespace-nowrap"><%= number_to_currency(tag[:amount]) %> <span class="text-[9px] text-gray-400 dark:text-gray-500"><%= tag[:pct] %>%</span></span>
                  </div>
                <% end %>
              <% else %>
                <p class="text-[11px] text-gray-400 dark:text-gray-500">No tagged payments.</p>
              <% end %>
            </div>
            <% tag_total = @spending_by_tag.sum { |t| t[:amount] } %>
            <% if @spending_by_tag.any? %>
              <div class="border-t border-gray-200 dark:border-gray-600 mt-2 pt-1">
                <div class="flex items-center justify-between">
                  <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200">Total</span>
                  <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200"><%= number_to_currency(tag_total) %></span>
                </div>
              </div>
            <% end %>
          </div>

          <%# === Column 4: Deposits Breakdown === %>
          <div class="flex flex-col min-w-0">
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-2 pb-1 border-b border-gray-200 dark:border-gray-600">Deposits</p>
            <div class="flex-1 space-y-0.5">
              <% if @deposits_breakdown.any? %>
                <% @deposits_breakdown.each do |dep| %>
                  <div class="flex items-baseline justify-between gap-1">
                    <span class="text-[11px] text-gray-700 dark:text-gray-300 truncate"><%= dep[:name] %></span>
                    <span class="text-[11px] font-medium text-gray-800 dark:text-gray-200 whitespace-nowrap"><%= number_to_currency(dep[:amount]) %> <span class="text-[9px] text-gray-400 dark:text-gray-500"><%= dep[:pct] %>%</span></span>
                  </div>
                <% end %>
              <% else %>
                <p class="text-[11px] text-gray-400 dark:text-gray-500">No deposits this month.</p>
              <% end %>
            </div>
            <% if @deposits_breakdown.any? %>
              <div class="border-t border-gray-200 dark:border-gray-600 mt-2 pt-1">
                <div class="flex items-center justify-between">
                  <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200">Total</span>
                  <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200"><%= number_to_currency(income_total) %></span>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <% if @cc_payoff[:total_current_balance] > 0 %>
        <div class="border-t border-gray-200 dark:border-gray-600 mt-3 pt-2">
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Credit Card Obligations</p>
          <div class="space-y-0.5">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-gray-600 dark:text-gray-400">Payments Due Now</span>
              <span class="text-[11px] font-medium text-red-500 dark:text-red-400 tabular-nums"><%= number_to_currency(@cc_payoff[:total_statement_balance]) %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-gray-600 dark:text-gray-400">New Charges Not Yet Due</span>
              <span class="text-[11px] font-medium text-gray-800 dark:text-gray-200 tabular-nums"><%= number_to_currency(@cc_payoff[:total_new_charges]) %></span>
            </div>
            <div class="flex items-center justify-between border-t border-gray-100 dark:border-gray-700 pt-0.5 mt-0.5">
              <span class="text-[11px] font-bold text-gray-800 dark:text-gray-200">Total Payoff Needed</span>
              <span class="text-[11px] font-bold text-red-500 dark:text-red-400 tabular-nums"><%= number_to_currency(@cc_payoff[:total_current_balance]) %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to spending overview">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <button type="button" data-action="click->dashboard#toggleCardExpand"
              data-role="expand-btn"
              class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
              aria-label="Expand Spending Details">
        <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
        </svg>
        <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
        </svg>
      </button>
    </div>
  </div>
</div>
