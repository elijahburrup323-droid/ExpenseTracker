<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <%= link_to report_spending_by_category_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open spending report" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
        <% end %>
      </div>
    </div>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="card-content">
      <div class="flex flex-col justify-center flex-1 py-2">
        <% has_plan = @three_month_avg.present? && @three_month_avg.to_f > 0 %>
        <% spent = @spent_mtd.to_f %>
        <% remaining = has_plan ? (@three_month_avg.to_f - spent) : 0 %>

        <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-1">This Month</p>

        <% if has_plan %>
          <p class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-1" style="font-variant-numeric: tabular-nums;">
            <%= number_to_currency(remaining.abs, precision: 0) %> <%= remaining >= 0 ? 'remaining' : 'over plan' %>
          </p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mb-2" style="font-variant-numeric: tabular-nums;">
            <%= number_to_currency(spent, precision: 0) %> of <%= number_to_currency(@three_month_avg, precision: 0) %> planned
          </p>
          <% if @days_remaining.to_i > 0 %>
            <% if remaining > 0 %>
              <p class="text-[11px] text-gray-400 dark:text-gray-500" style="font-variant-numeric: tabular-nums;">
                <%= number_to_currency((remaining / @days_remaining).round(2), precision: 2) %> per day available
              </p>
            <% elsif remaining == 0 %>
              <p class="text-[11px] text-gray-400 dark:text-gray-500">Plan reached</p>
            <% else %>
              <p class="text-[11px] text-amber-600 dark:text-amber-400" style="font-variant-numeric: tabular-nums;">
                Plan exceeded by <%= number_to_currency(remaining.abs, precision: 0) %>
              </p>
            <% end %>
          <% else %>
            <% if remaining >= 0 %>
              <p class="text-[11px] text-gray-400 dark:text-gray-500">Finished under plan</p>
            <% else %>
              <p class="text-[11px] text-amber-600 dark:text-amber-400" style="font-variant-numeric: tabular-nums;">
                Plan exceeded by <%= number_to_currency(remaining.abs, precision: 0) %>
              </p>
            <% end %>
          <% end %>
        <% else %>
          <p class="text-2xl font-bold text-slate-700 dark:text-slate-200 mb-1" style="font-variant-numeric: tabular-nums;">
            <%= number_to_currency(spent, precision: 0) %> spent this month
          </p>
        <% end %>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View spending by category">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to payments_path(start_date: @month_start.to_s, end_date: (@month_end - 1).to_s),
              class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          View Details &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Spending Overview">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  <%# === BACK SIDE (Category + Type Breakdowns) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Spending Breakdown</h2>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <%= link_to report_spending_by_category_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open spending report" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
        <% end %>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="back-content">
      <% has_plan = @three_month_avg.present? && @three_month_avg.to_f > 0 %>
      <% spent = @spent_mtd.to_f %>
      <% plan = @three_month_avg.to_f %>
      <% remaining = has_plan ? (plan - spent) : 0 %>
      <% days_in_month = @month_start.end_of_month.day %>
      <% is_current = @month_start == Date.today.beginning_of_month %>
      <% days_elapsed = is_current ? (Date.today - @month_start).to_i + 1 : days_in_month %>
      <% spending_pct = has_plan && plan > 0 ? [(spent / plan * 100).round(1), 100].min : 0 %>
      <% month_pct = days_in_month > 0 ? [(days_elapsed.to_f / days_in_month * 100).round(1), 100].min : 0 %>
      <% on_track = spending_pct <= month_pct %>
      <% projected = @projected_month_end.to_f %>

      <div class="space-y-4 py-2" style="max-width: 480px; margin: 0 auto;">
        <%# --- Section A: Plan vs Spent --- %>
        <div>
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-1.5">Plan vs Spent</p>
          <div class="flex items-baseline space-x-3" style="font-variant-numeric: tabular-nums;">
            <span class="text-sm text-gray-700 dark:text-gray-300">Spent <span class="font-semibold text-slate-800 dark:text-slate-100"><%= number_to_currency(spent, precision: 0) %></span></span>
            <% if has_plan %>
              <span class="text-[11px] text-gray-400 dark:text-gray-500">&middot;</span>
              <span class="text-sm text-gray-700 dark:text-gray-300">Plan <span class="font-semibold text-slate-800 dark:text-slate-100"><%= number_to_currency(plan, precision: 0) %></span></span>
            <% end %>
          </div>
          <% if has_plan %>
            <p class="text-xs mt-0.5 <%= remaining >= 0 ? 'text-gray-500 dark:text-gray-400' : 'text-amber-600 dark:text-amber-400' %>" style="font-variant-numeric: tabular-nums;">
              <%= number_to_currency(remaining.abs, precision: 0) %> <%= remaining >= 0 ? 'remaining' : 'over plan' %>
            </p>
          <% end %>
        </div>

        <% if has_plan %>
          <%# --- Section B: Pacing Bars --- %>
          <div>
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-1.5">Pacing</p>
            <div class="space-y-2">
              <div>
                <div class="flex items-center justify-between mb-0.5">
                  <span class="text-[11px] text-gray-500 dark:text-gray-400">Spending Used</span>
                  <span class="text-[11px] font-medium text-slate-700 dark:text-slate-300" style="font-variant-numeric: tabular-nums;"><%= spending_pct %>%</span>
                </div>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                  <div class="h-2 rounded-full transition-all" style="width: <%= spending_pct %>%; background: var(--brand-500, #7c3aed);"></div>
                </div>
              </div>
              <div>
                <div class="flex items-center justify-between mb-0.5">
                  <span class="text-[11px] text-gray-500 dark:text-gray-400">Month Elapsed</span>
                  <span class="text-[11px] font-medium text-slate-700 dark:text-slate-300" style="font-variant-numeric: tabular-nums;"><%= month_pct %>%</span>
                </div>
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                  <div class="h-2 rounded-full bg-slate-400 dark:bg-slate-500 transition-all" style="width: <%= month_pct %>%;"></div>
                </div>
              </div>
            </div>
            <p class="text-[11px] mt-1.5 font-medium <%= on_track ? 'text-green-600 dark:text-green-400' : 'text-amber-600 dark:text-amber-400' %>">
              <%= on_track ? '&#10003; On Track' : '&#9888; Ahead of Plan' %>
              <span class="font-normal text-gray-400 dark:text-gray-500">— spending <%= on_track ? 'behind' : 'ahead of' %> schedule</span>
            </p>
          </div>
        <% end %>

        <%# --- Section C: Projection --- %>
        <div>
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-1.5">Projection</p>
          <div class="flex items-baseline space-x-3" style="font-variant-numeric: tabular-nums;">
            <span class="text-sm text-gray-700 dark:text-gray-300">Projected <span class="font-semibold text-slate-800 dark:text-slate-100"><%= number_to_currency(projected, precision: 0) %></span></span>
            <% if has_plan %>
              <span class="text-[11px] text-gray-400 dark:text-gray-500">&middot;</span>
              <span class="text-sm text-gray-700 dark:text-gray-300">Plan <span class="font-semibold text-slate-800 dark:text-slate-100"><%= number_to_currency(plan, precision: 0) %></span></span>
            <% end %>
          </div>
          <% if has_plan %>
            <% proj_delta = projected - plan %>
            <p class="text-[11px] mt-0.5 <%= proj_delta <= 0 ? 'text-gray-500 dark:text-gray-400' : 'text-amber-600 dark:text-amber-400' %>" style="font-variant-numeric: tabular-nums;">
              ~<%= number_to_currency(proj_delta.abs, precision: 0) %> <%= proj_delta <= 0 ? 'under' : 'over' %> plan at current pace
            </p>
          <% else %>
            <p class="text-[11px] mt-0.5 text-gray-500 dark:text-gray-400">Based on <%= number_to_currency(@daily_avg || 0, precision: 2) %>/day average</p>
          <% end %>
        </div>

        <%# --- Section D: Top 3 Spending Drivers --- %>
        <% top_cats = @spending_by_category.first(3) %>
        <% if top_cats.any? %>
          <div>
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-1.5">Top Spending Drivers</p>
            <div class="space-y-1">
              <% top_cats.each do |cat| %>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-700 dark:text-gray-300 truncate"><%= cat[:name] %></span>
                  <div class="flex items-center space-x-2 flex-shrink-0 ml-2" style="font-variant-numeric: tabular-nums;">
                    <span class="text-xs font-semibold text-slate-800 dark:text-slate-100"><%= number_to_currency(cat[:amount]) %></span>
                    <% if cat[:limit].present? && cat[:limit].to_f > 0 %>
                      <% cat_delta = cat[:amount].to_f - cat[:limit].to_f %>
                      <span class="text-[10px] <%= cat_delta > 0 ? 'text-amber-600 dark:text-amber-400' : 'text-gray-400 dark:text-gray-500' %>">
                        <%= cat_delta > 0 ? "+#{number_to_currency(cat_delta, precision: 0)} over" : "#{number_to_currency(cat_delta.abs, precision: 0)} under" %>
                      </span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# --- Section E: Pacing Guidance --- %>
        <div class="pt-2 border-t border-gray-100 dark:border-gray-700">
          <% if has_plan %>
            <% if remaining > 0 && @days_remaining.to_i > 0 %>
              <p class="text-[11px] text-gray-500 dark:text-gray-400" style="font-variant-numeric: tabular-nums;">
                To stay on plan: ~<%= number_to_currency((remaining / @days_remaining).round(2), precision: 2) %>/day
              </p>
            <% elsif remaining == 0 %>
              <p class="text-[11px] text-gray-500 dark:text-gray-400">Plan reached — review spending drivers</p>
            <% else %>
              <p class="text-[11px] text-amber-600 dark:text-amber-400" style="font-variant-numeric: tabular-nums;">
                Over plan by <%= number_to_currency(remaining.abs, precision: 0) %> — see top drivers
              </p>
            <% end %>
          <% else %>
            <p class="text-[11px] text-gray-500 dark:text-gray-400" style="font-variant-numeric: tabular-nums;">
              <%= number_to_currency(@daily_avg || 0, precision: 2) %>/day average spending
            </p>
          <% end %>
        </div>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to spending overview">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to payments_path(start_date: @month_start.to_s, end_date: (@month_end - 1).to_s),
              class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          View Details &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Spending Breakdown">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>
