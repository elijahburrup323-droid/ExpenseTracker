<% spent_val = @spent_mtd.to_f %>
<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="card-content">
      <div class="flex items-center space-x-4 flex-1">
        <div class="relative w-24 h-24 lg:w-32 lg:h-32 flex-shrink-0">
          <svg viewBox="0 0 36 36" class="w-full h-full">
            <circle cx="18" cy="18" r="15.9155" fill="none" stroke="#e5e7eb" stroke-width="3" class="dark:opacity-30"/>
            <circle cx="18" cy="18" r="15.9155" fill="none" stroke="#a855f7" stroke-width="3"
                    stroke-dasharray="100 0" stroke-dashoffset="25" stroke-linecap="round"/>
          </svg>
          <div class="absolute inset-0 flex flex-col items-center justify-center">
            <span class="text-xs text-gray-500 dark:text-gray-400">Spent</span>
            <span class="text-sm font-bold text-gray-900 dark:text-white"><%= number_to_currency(spent_val, precision: 2) %></span>
          </div>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Available to Spend</p>
          <p class="text-xl font-bold <%= @available_to_spend.to_f >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(@available_to_spend || 0, precision: 2) %></p>
          <p class="text-[11px] text-gray-400 dark:text-gray-500 mt-1">Scheduled: <%= number_to_currency(@scheduled_remaining || 0, precision: 2) %></p>
          <% if @category_pressure.present? && @category_pressure.any? %>
            <% @category_pressure.each do |cat| %>
              <p class="text-[11px] mt-0.5 <%= cat[:limit_pct_used] >= 90 ? 'text-red-500 font-medium' : 'text-amber-500' %>">
                <svg class="w-3 h-3 inline -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
                <%= cat[:name] %> <%= cat[:limit_pct_used] %>%
              </p>
            <% end %>
          <% end %>
          <div class="mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
            <div class="flex items-baseline space-x-2">
              <p class="text-sm font-semibold text-gray-800 dark:text-gray-200" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(@safe_daily_spend || 0, precision: 2) %></p>
              <p class="text-[11px] text-gray-500 dark:text-gray-400">safe / day</p>
              <p class="text-[11px] text-gray-400 dark:text-gray-500"><%= @days_remaining || 0 %> days left</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View spending by category">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to payments_path(start_date: @month_start.to_s, end_date: (@month_end - 1).to_s),
              class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          View Details &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Spending Overview">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  <%# === BACK SIDE (Category + Type Breakdowns) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg);">
    <div class="flex items-center justify-between mb-3">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Spending Breakdown</h2>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="back-content">
      <% color_map = { "blue" => "#3b82f6", "green" => "#22c55e", "gold" => "#eab308", "red" => "#ef4444", "purple" => "#a855f7", "pink" => "#ec4899", "indigo" => "#6366f1", "teal" => "#14b8a6", "orange" => "#f97316", "gray" => "#6b7280" } %>
      <% has_tags = @spending_by_tag.present? && @spending_by_tag.any? %>
      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;" data-role="breakdown-grid">
        <%# --- Column 1: By Category --- %>
        <div class="flex flex-col">
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-2">By Category</p>
          <% if @spending_by_category.any? %>
            <div class="space-y-1 flex-1">
              <% @spending_by_category.each do |cat| %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-1.5 min-w-0 flex-1">
                    <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: <%= color_map[cat[:color_key]] || '#6b7280' %>"></span>
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate"><%= cat[:name] %></span>
                  </div>
                  <div class="flex items-center space-x-1 flex-shrink-0 ml-1">
                    <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(cat[:amount]) %></span>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right" style="font-variant-numeric: tabular-nums;"><%= cat[:pct] %>%</span>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="flex items-center justify-end mt-2 pt-1.5 border-t border-gray-200 dark:border-gray-600">
              <div class="flex items-center space-x-1">
                <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(@spending_by_category.sum { |c| c[:amount].to_f }) %></span>
                <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right">&nbsp;</span>
              </div>
            </div>
          <% else %>
            <p class="text-xs text-gray-400 dark:text-gray-500 flex-1">No spending yet.</p>
            <div class="flex items-center justify-end mt-2 pt-1.5 border-t border-gray-200 dark:border-gray-600">
              <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(0) %></span>
            </div>
          <% end %>
        </div>

        <%# --- Column 2: By Spending Type --- %>
        <div class="flex flex-col">
          <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-2">By Spending Type</p>
          <% if @spending_by_type.any? %>
            <div class="space-y-1 flex-1">
              <% @spending_by_type.each do |st| %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-1.5 min-w-0 flex-1">
                    <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: <%= color_map[st[:color_key]] || '#6b7280' %>"></span>
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate"><%= st[:name] %></span>
                  </div>
                  <div class="flex items-center space-x-1 flex-shrink-0 ml-1">
                    <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(st[:amount]) %></span>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right" style="font-variant-numeric: tabular-nums;"><%= st[:pct] %>%</span>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="flex items-center justify-end mt-2 pt-1.5 border-t border-gray-200 dark:border-gray-600">
              <div class="flex items-center space-x-1">
                <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(@spending_by_type.sum { |t| t[:amount].to_f }) %></span>
                <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right">&nbsp;</span>
              </div>
            </div>
          <% else %>
            <p class="text-xs text-gray-400 dark:text-gray-500 flex-1">No spending yet.</p>
            <div class="flex items-center justify-end mt-2 pt-1.5 border-t border-gray-200 dark:border-gray-600">
              <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(0) %></span>
            </div>
          <% end %>
        </div>

        <% if has_tags %>
          <%# --- Column 3: By Tag --- %>
          <div class="flex flex-col">
            <p class="text-[10px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-widest mb-2">By Tag</p>
            <div class="space-y-1 flex-1">
              <% @spending_by_tag.each do |tag| %>
                <div class="flex items-center justify-between">
                  <div class="flex items-center space-x-1.5 min-w-0 flex-1">
                    <span class="w-2 h-2 rounded-full flex-shrink-0 bg-brand-400"></span>
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate"><%= tag[:name] %></span>
                  </div>
                  <div class="flex items-center space-x-1 flex-shrink-0 ml-1">
                    <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(tag[:amount]) %></span>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right" style="font-variant-numeric: tabular-nums;"><%= tag[:pct] %>%</span>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="flex items-center justify-end mt-2 pt-1.5 border-t border-gray-200 dark:border-gray-600">
              <div class="flex items-center space-x-1">
                <span class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(@spending_by_tag.sum { |t| t[:amount].to_f }) %></span>
                <span class="text-[10px] text-gray-400 dark:text-gray-500 w-8 text-right">&nbsp;</span>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to spending overview">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to payments_path(start_date: @month_start.to_s, end_date: (@month_end - 1).to_s),
              class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          View Details &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Spending Breakdown">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>
