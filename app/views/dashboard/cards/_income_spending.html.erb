<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE: Income & Spending summary === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <%= link_to report_monthly_cash_flow_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open cash flow report" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
        <% end %>
      </div>
    </div>
    <%# === Calm Snapshot: 4-line equation stack (Instruction N) === %>
    <div class="flex-1 min-h-0 overflow-y-auto flex flex-col justify-center py-3" data-role="card-content">
      <div class="space-y-1.5">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600 dark:text-gray-400">Beginning Balance</span>
          <span class="text-sm text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(@beginning_balance_total) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600 dark:text-gray-400">+ Deposits</span>
          <span class="text-sm text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(@current_month_income) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600 dark:text-gray-400">&minus; Payments</span>
          <span class="text-sm text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(@current_month_payments) %></span>
        </div>
        <% if @net_transfers && @net_transfers != 0 %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= @net_transfers > 0 ? "+ Transfers In" : "&minus; Transfers Out".html_safe %></span>
            <span class="text-sm text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(@net_transfers.abs) %></span>
          </div>
        <% end %>
        <% if @budget_adjustments && @budget_adjustments != 0 %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-gray-600 dark:text-gray-400"><%= @budget_adjustments > 0 ? "+ Adjustments" : "&minus; Adjustments".html_safe %></span>
            <span class="text-sm text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(@budget_adjustments.abs) %></span>
          </div>
        <% end %>
        <div class="border-t border-gray-200 dark:border-gray-600 my-1"></div>
        <div class="flex items-center justify-between">
          <span class="number-base text-gray-900 dark:text-white">= Current Balance</span>
          <span class="number-base text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@budget_total) %></span>
        </div>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View recent deposits">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Income & Spending Card">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>

  <%# === BACK SIDE: Expanded Clarity (Instruction O) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Monthly Details</h2>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <%= link_to report_monthly_cash_flow_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open cash flow report" } do %>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
        <% end %>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="back-content">
      <%# Equation stack repeated at top %>
      <div class="space-y-1 mb-3">
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500 dark:text-gray-400">Beginning Balance</span>
          <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(@beginning_balance_total) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500 dark:text-gray-400">+ Deposits</span>
          <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(@current_month_income) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-xs text-gray-500 dark:text-gray-400">&minus; Payments</span>
          <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(@current_month_payments) %></span>
        </div>
        <% if @net_transfers && @net_transfers != 0 %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500 dark:text-gray-400"><%= @net_transfers > 0 ? "+ Transfers In" : "&minus; Transfers Out".html_safe %></span>
            <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(@net_transfers.abs) %></span>
          </div>
        <% end %>
        <% if @budget_adjustments && @budget_adjustments != 0 %>
          <div class="flex items-center justify-between">
            <span class="text-xs text-gray-500 dark:text-gray-400"><%= @budget_adjustments > 0 ? "+ Adjustments" : "&minus; Adjustments".html_safe %></span>
            <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(@budget_adjustments.abs) %></span>
          </div>
        <% end %>
        <div class="border-t border-gray-200 dark:border-gray-600 my-0.5"></div>
        <div class="flex items-center justify-between">
          <span class="text-sm font-bold text-gray-900 dark:text-white">= Current Balance</span>
          <span class="text-sm font-bold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@budget_total) %></span>
        </div>
      </div>

      <%# Net Change %>
      <% net_change = @current_month_income.to_f - @current_month_payments.to_f %>
      <div class="flex items-center justify-between mb-3">
        <span class="text-xs text-gray-500 dark:text-gray-400">Net Change</span>
        <span class="text-xs font-semibold text-gray-600 dark:text-gray-300 tabular-nums"><%= net_change >= 0 ? "+#{number_to_currency(net_change)}" : number_to_currency(net_change) %></span>
      </div>

      <%# Top 3 Payments %>
      <% top_payments = @spending_by_category.first(3) %>
      <div class="mb-3">
        <span class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Top Payments</span>
        <% if top_payments.any? %>
          <div class="mt-1 space-y-1">
            <% top_payments.each do |cat| %>
              <div class="flex items-center justify-between">
                <span class="text-xs text-gray-600 dark:text-gray-400 truncate mr-2"><%= cat[:name] %></span>
                <span class="text-xs text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(cat[:amount]) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">No payments this month.</p>
        <% end %>
      </div>

      <%# Top 3 Deposits %>
      <div>
        <span class="text-[11px] font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide">Top Deposits</span>
        <% top_deposits = @recent_income_entries.sort_by { |e| -e.amount.to_f }.first(3) %>
        <% if top_deposits.any? %>
          <div class="mt-1 space-y-1">
            <% top_deposits.each do |entry| %>
              <div class="flex items-center justify-between">
                <span class="text-xs text-gray-600 dark:text-gray-400 truncate mr-2"><%= entry.description %></span>
                <span class="text-xs text-gray-700 dark:text-gray-300 tabular-nums"><%= number_to_currency(entry.amount) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">No deposits this month.</p>
        <% end %>
      </div>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to income & spending">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Income & Spending Card">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
