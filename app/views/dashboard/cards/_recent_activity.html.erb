<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE: Recent Payments Only === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Recent Payments</h2>
      </div>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex items-center justify-between px-1 mb-2" data-role="activity-summary">
      <span class="text-xs font-medium tabular-nums text-red-500 dark:text-red-400">
        Total: &minus;<%= number_to_currency(@recent_payment_items.sum { |i| i[:amount] }) %>
      </span>
      <span class="text-xs text-gray-400 dark:text-gray-500"><%= @payment_count %> payment<%= @payment_count == 1 ? '' : 's' %></span>
    </div>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="card-content">
      <div class="max-h-[220px] overflow-y-auto" data-role="payment-list">
        <% if @recent_payment_items.any? %>
          <div class="space-y-1.5">
            <% @recent_payment_items.each do |item| %>
              <div class="flex items-center py-1.5 text-sm border-b border-gray-50 dark:border-gray-800 last:border-0">
                <span class="w-8 flex-shrink-0 text-xs text-gray-400 tabular-nums"><%= item[:date].strftime("%-m/%-d") %></span>
                <span class="flex-1 text-gray-700 dark:text-gray-300 truncate px-2 text-xs"><%= item[:description] %></span>
                <span class="text-red-500 dark:text-red-400 font-medium tabular-nums flex-shrink-0 text-xs">&minus;<%= number_to_currency(item[:amount].abs) %></span>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">No payments this month.</p>
        <% end %>
      </div>
      <a href="<%= payments_path %>" class="block text-center text-brand-600 dark:text-brand-400 text-xs font-semibold py-2 mt-1">
        Manage Payments
      </a>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View recent deposits">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Recent Deposits</span>
      </button>
    </div>
  </div>

  <%# === BACK SIDE: Recent Deposits Only === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Recent Deposits</h2>
      <div class="flex items-center space-x-2">
        <button type="button" data-action="click->dashboard#prevMonth" data-dashboard-target="prevBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <span class="text-xs text-gray-500 dark:text-gray-400 min-w-[5.5rem] text-center" data-dashboard-target="monthLabel"><%= Date.new(@open_month.current_year, @open_month.current_month, 1).strftime("%B %Y") %></span>
        <button type="button" data-action="click->dashboard#nextMonth" data-dashboard-target="nextBtn" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
    <div class="flex items-center justify-between px-1 mb-2" data-role="deposit-summary">
      <span class="text-xs font-medium tabular-nums text-emerald-500/80 dark:text-emerald-400/70">
        Total: +<%= number_to_currency(@recent_deposit_items.sum { |i| i[:amount] }) %>
      </span>
      <span class="text-xs text-gray-400 dark:text-gray-500"><%= @deposit_count %> deposit<%= @deposit_count == 1 ? '' : 's' %></span>
    </div>
    <div class="flex-1 min-h-0 overflow-y-auto" data-role="back-content">
      <% if @recent_deposit_items.any? %>
        <div class="space-y-1.5">
          <% @recent_deposit_items.each do |item| %>
            <div class="flex items-center justify-between">
              <div class="min-w-0 flex-1 mr-2">
                <span class="text-[11px] text-gray-400 dark:text-gray-500"><%= item[:date].strftime("%-m/%-d") %></span>
                <span class="text-xs text-gray-700 dark:text-gray-300 truncate"><%= item[:description] %></span>
              </div>
              <span class="text-xs font-medium text-emerald-500/80 dark:text-emerald-400/70 tabular-nums flex-shrink-0">+<%= number_to_currency(item[:amount]) %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">No deposits this month.</p>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to recent payments">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Recent Payments</span>
      </button>
      <div class="flex-1 flex items-center justify-center">
        <%= link_to income_entries_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Deposits
        <% end %>
      </div>
    </div>
  </div>
</div>
