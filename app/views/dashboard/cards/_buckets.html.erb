<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE: Simplified bucket list === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="card-content">
      <% if @buckets_summary[:empty] %>
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-4">No buckets yet. Create one to start allocating money.</p>
      <% else %>
        <%# === SIMPLE LAYOUT (small card mode) === %>
        <div data-role="simple-layout">
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs text-gray-500 dark:text-gray-400"><%= @buckets_summary[:count] %> bucket<%= @buckets_summary[:count] != 1 ? "s" : "" %></span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white"><%= number_to_currency(@buckets_summary[:total_balance]) %></span>
          </div>
          <div class="space-y-3">
            <% @buckets_summary[:account_groups].each do |group| %>
              <div>
                <div class="mb-1">
                  <span class="text-xs font-bold text-gray-800 dark:text-gray-200 uppercase tracking-wider"><%= group[:account_name] %></span>
                </div>
                <div class="space-y-1.5 pl-2 border-l-2 border-gray-200 dark:border-gray-600">
                  <% group[:buckets].each do |b| %>
                    <div>
                      <div class="flex items-center justify-between">
                        <div class="flex items-center min-w-0">
                          <span class="text-sm text-gray-700 dark:text-gray-300 truncate"><%= b.name %></span>
                          <% if b.is_default %>
                            <span class="ml-1 text-[10px] font-medium text-brand-600 dark:text-brand-400">(Default)</span>
                          <% end %>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 dark:text-white ml-2 flex-shrink-0"><%= number_to_currency(b.current_balance) %></span>
                      </div>
                      <% if b.target_amount.present? && b.target_amount > 0 %>
                        <% pct = [(b.current_balance.to_f / b.target_amount.to_f * 100).round(1), 100].min %>
                        <% bar_color = pct >= 100 ? "bg-green-500" : pct >= 50 ? "bg-brand-500" : "bg-yellow-500" %>
                        <div class="mt-1 w-full h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                          <div class="<%= bar_color %> h-full rounded-full" style="width: <%= pct %>%"></div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <%# === EXPANDED LAYOUT (CM-24: full detail with financial columns) === %>
        <div data-role="expanded-layout">
          <div class="flex items-center justify-between mb-4">
            <span class="text-sm text-gray-500 dark:text-gray-400"><%= @buckets_summary[:count] %> bucket<%= @buckets_summary[:count] != 1 ? "s" : "" %></span>
            <span class="text-sm font-semibold text-gray-900 dark:text-white">Total: <%= number_to_currency(@buckets_summary[:total_balance]) %></span>
          </div>
          <div class="space-y-4">
            <% @buckets_summary[:account_groups].each do |group| %>
              <div>
                <div class="flex items-center justify-between mb-2 pb-1 border-b border-gray-200 dark:border-gray-600">
                  <span class="text-xs font-bold text-gray-800 dark:text-gray-200 uppercase tracking-wider"><%= group[:account_name] %></span>
                  <span class="text-xs font-semibold text-gray-700 dark:text-gray-300"><%= number_to_currency(group[:account_total]) %></span>
                </div>
                <div class="space-y-3">
                  <% group[:buckets].each do |b| %>
                    <%
                      has_target = b.target_amount.present? && b.target_amount > 0
                      has_max_spend = b.max_spend_per_year.present?
                      pct = has_target ? [(b.current_balance.to_f / b.target_amount.to_f * 100).round(1), 100].min : 0
                      bar_color = pct >= 100 ? "bg-green-500" : pct >= 50 ? "bg-brand-500" : "bg-yellow-500"
                      spent_val = has_max_spend ? b.spent_ytd.to_f : 0
                      remaining = has_max_spend ? (b.max_spend_per_year.to_f - spent_val) : nil
                    %>
                    <div class="flex items-start gap-4">
                      <%# LEFT SECTION: Name + Current/Target + Progress bar %>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center">
                          <span class="text-sm font-semibold text-gray-900 dark:text-white truncate"><%= b.name %></span>
                          <% if b.is_default %>
                            <span class="ml-1.5 text-[10px] font-medium text-brand-600 dark:text-brand-400">(Default)</span>
                          <% end %>
                        </div>
                        <% if has_target %>
                          <div class="mt-1 text-xs font-medium text-gray-700 dark:text-gray-300" style="font-variant-numeric: tabular-nums;">
                            <%= number_to_currency(b.current_balance) %> of <%= number_to_currency(b.target_amount) %>
                          </div>
                          <div class="mt-1 w-full h-2 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                            <div class="<%= bar_color %> h-full rounded-full" style="width: <%= pct %>%"></div>
                          </div>
                        <% else %>
                          <div class="mt-1 text-xs text-gray-500 dark:text-gray-400" style="font-variant-numeric: tabular-nums;">
                            Balance: <%= number_to_currency(b.current_balance) %>
                          </div>
                        <% end %>
                      </div>
                      <%# RIGHT SECTION: Max Spend/Yr | Spent | Remaining %>
                      <% if has_max_spend %>
                        <div class="flex items-start gap-4 flex-shrink-0 pt-0.5">
                          <div class="text-right" style="min-width: 5.5rem;">
                            <div class="text-[10px] text-gray-500 dark:text-gray-400 uppercase">Max Spend/Yr</div>
                            <div class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(b.max_spend_per_year) %></div>
                          </div>
                          <div class="text-right" style="min-width: 4.5rem;">
                            <div class="text-[10px] text-gray-500 dark:text-gray-400 uppercase">Spent</div>
                            <div class="text-xs font-semibold text-gray-900 dark:text-white" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(spent_val) %></div>
                          </div>
                          <div class="text-right" style="min-width: 4.5rem;">
                            <div class="text-[10px] text-gray-500 dark:text-gray-400 uppercase">Remaining</div>
                            <div class="text-xs font-semibold <%= remaining && remaining > 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>" style="font-variant-numeric: tabular-nums;"><%= number_to_currency(remaining || 0) %></div>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-auto border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View bucket details">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to buckets_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Buckets &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Buckets Card">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%# === BACK SIDE: Detail view with account totals and metrics === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Bucket Details</h2>
    </div>
    <div class="flex-1 overflow-y-auto">
      <% unless @buckets_summary[:empty] %>
        <div class="space-y-3">
          <% @buckets_summary[:account_groups].each do |group| %>
            <div>
              <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-bold text-gray-800 dark:text-gray-200 uppercase tracking-wider"><%= group[:account_name] %></span>
                <span class="text-xs font-semibold text-gray-700 dark:text-gray-300"><%= number_to_currency(group[:account_total]) %></span>
              </div>
              <div class="space-y-1 pl-2 border-l-2 border-gray-200 dark:border-gray-600">
                <% group[:buckets].each do |b| %>
                  <div>
                    <div class="flex items-center justify-between">
                      <span class="text-xs text-gray-600 dark:text-gray-400 truncate"><%= b.name %></span>
                      <span class="text-xs font-semibold text-gray-900 dark:text-white ml-2"><%= number_to_currency(b.current_balance) %></span>
                    </div>
                    <% if b.max_spend_per_year.present? %>
                      <div class="flex justify-between text-[10px] text-gray-400 dark:text-gray-500">
                        <span>Avail: <span class="<%= b.available_to_spend <= 0 ? 'text-red-500' : 'text-green-600 dark:text-green-400' %> font-semibold"><%= number_to_currency(b.available_to_spend) %></span></span>
                        <span>of <%= number_to_currency(b.max_spend_per_year) %>/yr</span>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="mt-auto border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to buckets overview">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to buckets_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Buckets &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Buckets Card">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>
