<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE: Bucket overview === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
    </div>
    <%# === Calm Goals Snapshot (Instruction P) === %>
    <div class="flex-1 min-h-0 overflow-y-auto pt-2" data-role="card-content">
      <% if @buckets_summary[:empty] %>
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center pt-3">No buckets yet. Create one to start allocating money.</p>
      <% else %>
        <div class="text-center mb-3">
          <span class="text-lg font-bold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@buckets_summary[:total_balance]) %></span>
          <span class="text-xs text-gray-500 dark:text-gray-400 ml-1">saved in <%= @buckets_summary[:count] %> bucket<%= @buckets_summary[:count] != 1 ? "s" : "" %></span>
        </div>
        <div class="space-y-2.5">
          <% (@buckets_summary[:priority_sorted] || []).each do |b| %>
            <%
              has_goal = b.target_amount.present? && b.target_amount > 0
              pct = has_goal ? [(b.current_balance.to_f / b.target_amount.to_f * 100).round(1), 100].min : nil
              goal_met = has_goal && b.current_balance.to_f >= b.target_amount.to_f
              bar_color = goal_met ? "bg-amber-500" : "bg-emerald-500"
            %>
            <div>
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-1.5 min-w-0">
                  <span class="text-xs font-medium text-gray-900 dark:text-white truncate"><%= b.name %></span>
                  <% if goal_met %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded-full text-[9px] font-semibold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400">&#10003; Goal Met</span>
                  <% end %>
                </div>
                <% if has_goal %>
                  <span class="text-[10px] text-gray-500 dark:text-gray-400 tabular-nums flex-shrink-0 ml-1"><%= number_to_currency(b.current_balance, precision: 0) %> / <%= number_to_currency(b.target_amount, precision: 0) %></span>
                <% else %>
                  <span class="text-[10px] text-gray-500 dark:text-gray-400 tabular-nums flex-shrink-0 ml-1"><%= number_to_currency(b.current_balance) %></span>
                <% end %>
              </div>
              <% if has_goal %>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <div class="flex-1 h-1.5 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                    <div class="<%= bar_color %> h-full rounded-full" style="width: <%= pct %>%"></div>
                  </div>
                  <span class="text-[9px] text-gray-400 dark:text-gray-500 tabular-nums w-7 text-right"><%= pct.to_i %>%</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View bucket details">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Bucket History</span>
      </button>
      <div class="flex-1 flex items-center justify-center">
        <%= link_to buckets_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Buckets
        <% end %>
      </div>
    </div>
  </div>

  <%# === BACK SIDE: Structured Goal Progress (Instruction Q) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Goal Progress</h2>
    </div>
    <div class="flex-1 overflow-y-auto" data-role="back-content">
      <% unless @buckets_summary[:empty] %>
        <%# Total saved pinned at top %>
        <div class="text-center mb-3">
          <span class="text-lg font-bold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(@buckets_summary[:total_balance]) %> saved in goals</span>
        </div>

        <%# Priority-sorted bucket list %>
        <div class="space-y-3">
          <% (@buckets_summary[:priority_sorted] || []).each do |b| %>
            <%
              has_target = b.target_amount.present? && b.target_amount > 0
              pct = has_target ? [(b.current_balance.to_f / b.target_amount.to_f * 100).round(1), 100].min : nil
              remaining = has_target ? [(b.target_amount.to_f - b.current_balance.to_f).round(2), 0].max : nil
              bar_color = pct && pct >= 100 ? "bg-green-500" : pct && pct >= 50 ? "bg-gray-400" : "bg-gray-300"
            %>
            <div>
              <div class="flex items-center justify-between">
                <span class="text-xs font-semibold text-gray-900 dark:text-white"><%= b.name %></span>
                <span class="text-xs text-gray-600 dark:text-gray-300 tabular-nums"><%= number_to_currency(b.current_balance) %></span>
              </div>
              <% if has_target %>
                <div class="flex items-center justify-between mt-0.5">
                  <span class="text-[10px] text-gray-400 dark:text-gray-500 tabular-nums">Target: <%= number_to_currency(b.target_amount) %></span>
                  <% if remaining && remaining > 0 %>
                    <span class="text-[10px] text-gray-400 dark:text-gray-500 tabular-nums"><%= number_to_currency(remaining) %> remaining</span>
                  <% end %>
                </div>
                <div class="mt-1 h-1 bg-gray-200 dark:bg-gray-600 rounded-full overflow-hidden">
                  <div class="<%= bar_color %> h-full rounded-full" style="width: <%= pct %>%"></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to buckets overview">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Buckets</span>
      </button>
      <div class="flex-1 flex items-center justify-center">
        <%= link_to buckets_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Buckets
        <% end %>
      </div>
    </div>
  </div>
</div>
