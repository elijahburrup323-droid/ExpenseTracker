<%
  credit_master_ids = AccountTypeMaster.where(normal_balance_type: "CREDIT").pluck(:id).to_set
  liquid_master_ids = AccountTypeMaster.liquid_type_ids.to_set
  revolving_credit_ids = AccountTypeMaster.where(normalized_key: AccountTypeMaster::CREDIT_TYPE_KEYS).pluck(:id).to_set

  # Compute liquid (cash) totals
  liquid_accounts = @accounts.select { |a| liquid_master_ids.include?(a.account_type_master_id) }
  liquid_total = liquid_accounts.sum { |a| a.balance.to_f }
  liquid_count = liquid_accounts.size

  # Liability accounts: credit cards vs loans
  liability_accounts = @accounts.select { |a| credit_master_ids.include?(a.account_type_master_id) }
  credit_accounts = @accounts.select { |a| revolving_credit_ids.include?(a.account_type_master_id) }
  credit_sum = credit_accounts.sum { |a| a.balance.to_f.abs }
  loan_accounts = liability_accounts.reject { |a| revolving_credit_ids.include?(a.account_type_master_id) }
  loan_sum = loan_accounts.sum { |a| a.balance.to_f.abs }
%>
<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE (Calm Cash — Total Cash only) === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div data-role="front-content" class="dash-card-scroll">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
      </div>
      <% if @accounts.empty? %>
        <p class="text-sm text-gray-400 dark:text-gray-500">No accounts yet.</p>
      <% else %>
        <%
          grouped_accounts = @accounts.includes(:account_type_master)
                                      .order("account_type_masters.sort_order, accounts.name")
                                      .group_by { |a| a.account_type_master&.display_name || "Other" }
          total_row_count = grouped_accounts.sum { |_, accts| 1 + accts.size }
        %>
        <div class="<%= total_row_count > 8 ? 'max-h-[200px] overflow-y-auto' : '' %> space-y-1 pt-1" style="font-variant-numeric: tabular-nums;">
          <% grouped_accounts.each do |group_name, accts| %>
            <%
              is_liability = credit_master_ids.include?(accts.first.account_type_master_id)
              group_total = accts.sum { |a| a.balance.to_f }
            %>
            <div class="flex items-center justify-between bg-gray-50 dark:bg-gray-700/50 rounded px-2 py-1">
              <span class="text-[11px] font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider"><%= group_name %></span>
              <span class="text-[11px] font-semibold tabular-nums <%= is_liability ? 'text-red-500 dark:text-red-400' : 'text-gray-900 dark:text-white' %>">
                <%= is_liability && group_total.abs > 0 ? "(#{number_to_currency(group_total.abs)})" : number_to_currency(group_total) %>
              </span>
            </div>
            <% accts.each do |account| %>
              <div class="flex items-center justify-between pl-5 pr-2">
                <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                <span class="text-xs tabular-nums flex-shrink-0 <%= is_liability ? 'text-red-500 dark:text-red-400' : 'text-gray-900 dark:text-white' %>">
                  <%= is_liability && account.balance.to_f.abs > 0 ? "(#{number_to_currency(account.balance.to_f.abs)})" : number_to_currency(account.balance.to_f) %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View assets vs liabilities">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Account History</span>
      </button>
      <div class="flex-1 flex items-center justify-center">
        <%= link_to accounts_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Accounts
        <% end %>
      </div>
    </div>
  </div>
  <%#
    === BACK SIDE (Grouped Structure — Instruction K) ===
    3 sections: Liquid (expanded), Credit (collapsed), Loans (collapsed)
  %>
  <%
    liquid_accounts_sorted = liquid_accounts.sort_by { |a| -a.balance.to_f }
    credit_accounts_sorted = credit_accounts.sort_by { |a| -a.balance.to_f.abs }
    loan_accounts_sorted = loan_accounts.sort_by { |a| -a.balance.to_f.abs }
  %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div data-role="back-content" class="dash-card-scroll">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Account Groups</h2>
      </div>
      <% if @accounts.empty? %>
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-8">No account data available.</p>
      <% else %>
        <%# --- 1) Liquid Accounts (Expanded by Default) --- %>
        <div class="mb-3" data-acct-section="liquid">
          <button type="button" onclick="this.closest('[data-acct-section]').querySelector('[data-section-body]').classList.toggle('hidden'); this.querySelector('[data-chevron]').classList.toggle('rotate-90')" class="flex items-center justify-between w-full text-left">
            <div class="flex items-center space-x-1.5">
              <svg data-chevron class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 rotate-90 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Liquid Accounts</span>
            </div>
            <span class="text-xs font-semibold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(liquid_total) %></span>
          </button>
          <div data-section-body class="mt-1.5">
            <% if liquid_accounts_sorted.any? %>
              <ul class="space-y-1">
                <% liquid_accounts_sorted.each do |account| %>
                  <li class="flex items-center justify-between pl-5">
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                    <span class="text-xs font-semibold text-gray-900 dark:text-white tabular-nums flex-shrink-0"><%= number_to_currency(account.balance.to_f) %></span>
                  </li>
                <% end %>
              </ul>
              <div class="flex items-center justify-between pl-5 mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
                <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Total Liquid</span>
                <span class="text-xs font-semibold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(liquid_total) %></span>
              </div>
            <% else %>
              <p class="text-xs text-gray-400 dark:text-gray-500 pl-5">No liquid accounts.</p>
            <% end %>
          </div>
        </div>
        <%# --- 2) Credit Accounts (Collapsed by Default) --- %>
        <div class="mb-3" data-acct-section="credit">
          <button type="button" onclick="this.closest('[data-acct-section]').querySelector('[data-section-body]').classList.toggle('hidden'); this.querySelector('[data-chevron]').classList.toggle('rotate-90')" class="flex items-center justify-between w-full text-left">
            <div class="flex items-center space-x-1.5">
              <svg data-chevron class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Credit Accounts</span>
            </div>
            <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums"><%= credit_sum > 0 ? "-" : "" %><%= number_to_currency(credit_sum) %></span>
          </button>
          <div data-section-body class="mt-1.5 hidden">
            <% if credit_accounts_sorted.any? %>
              <ul class="space-y-1">
                <% credit_accounts_sorted.each do |account| %>
                  <li class="flex items-center justify-between pl-5">
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                    <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums flex-shrink-0"><%= number_to_currency(-account.balance.to_f.abs) %></span>
                  </li>
                <% end %>
              </ul>
              <div class="flex items-center justify-between pl-5 mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
                <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Total Credit</span>
                <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums"><%= credit_sum > 0 ? "-" : "" %><%= number_to_currency(credit_sum) %></span>
              </div>
            <% else %>
              <p class="text-xs text-gray-400 dark:text-gray-500 pl-5">No credit accounts.</p>
            <% end %>
          </div>
        </div>
        <%# --- 3) Loans / Financing (Collapsed by Default) --- %>
        <div data-acct-section="loans">
          <button type="button" onclick="this.closest('[data-acct-section]').querySelector('[data-section-body]').classList.toggle('hidden'); this.querySelector('[data-chevron]').classList.toggle('rotate-90')" class="flex items-center justify-between w-full text-left">
            <div class="flex items-center space-x-1.5">
              <svg data-chevron class="w-3.5 h-3.5 text-gray-400 dark:text-gray-500 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <span class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Loans / Financing</span>
            </div>
            <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums"><%= loan_sum > 0 ? "-" : "" %><%= number_to_currency(loan_sum) %></span>
          </button>
          <div data-section-body class="mt-1.5 hidden">
            <% if loan_accounts_sorted.any? %>
              <ul class="space-y-1">
                <% loan_accounts_sorted.each do |account| %>
                  <li class="flex items-center justify-between pl-5">
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                    <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums flex-shrink-0"><%= number_to_currency(-account.balance.to_f.abs) %></span>
                  </li>
                <% end %>
              </ul>
              <div class="flex items-center justify-between pl-5 mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
                <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Total Loans</span>
                <span class="text-xs font-semibold text-red-500 dark:text-red-400 tabular-nums"><%= loan_sum > 0 ? "-" : "" %><%= number_to_currency(loan_sum) %></span>
              </div>
            <% else %>
              <p class="text-xs text-gray-400 dark:text-gray-500 pl-5">No loan accounts.</p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center gap-1.5 text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to accounts list">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
        <span class="text-[10px] font-medium">Accounts Overview</span>
      </button>
    </div>
  </div>
</div>
