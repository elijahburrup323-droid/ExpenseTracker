<%
  color_cycle = %w[blue green purple amber sky red]
  credit_master_ids = AccountTypeMaster.where(normal_balance_type: "CREDIT").pluck(:id).to_set
  nw_data = Account.net_worth_for(@accounts, user: current_user)
  card2_total = nw_data[:accounts_total]

  # Split into assets (DEBIT) and liabilities (CREDIT)
  asset_accounts = @accounts.select { |a| !credit_master_ids.include?(a.account_type_master_id) }
  liability_accounts = @accounts.select { |a| credit_master_ids.include?(a.account_type_master_id) }
  asset_accounts_sorted = asset_accounts.sort_by { |a| -a.balance.to_f }
  liability_accounts_sorted = liability_accounts.sort_by { |a| -a.balance.to_f.abs }
  assets_sum = asset_accounts.sum { |a| a.balance.to_f }
  liabilities_sum = liability_accounts.sum { |a| a.balance.to_f.abs }
  bar_total = assets_sum + liabilities_sum
  assets_pct = bar_total > 0 ? (assets_sum / bar_total * 100).round(0) : 0
  liabilities_pct = bar_total > 0 ? (liabilities_sum / bar_total * 100).round(0) : 0
%>
<div class="relative flex-1 flex flex-col" data-role="flipper" style="transform-style: preserve-3d; transition: transform 0.6s;">
  <%# === FRONT SIDE (Assets & Liabilities grouped) === %>
  <div class="flex flex-col flex-1" data-role="front" style="backface-visibility: hidden;">
    <div data-role="front-content" class="dash-card-scroll">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200"><%= card.title %></h2>
        <div class="flex items-center">
          <span class="text-sm font-semibold text-gray-900 dark:text-white tabular-nums">Accounts Total: <%= number_to_currency(card2_total) %></span>
          <%= link_to report_account_balance_history_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open accounts report" } do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
          <% end %>
        </div>
      </div>
      <% if @accounts.empty? %>
        <p class="text-sm text-gray-400 dark:text-gray-500">No accounts yet.</p>
      <% else %>
        <%# --- Assets Section --- %>
        <div class="mb-2">
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Assets</p>
          <% if asset_accounts_sorted.any? %>
            <ul class="space-y-1.5">
              <% asset_accounts_sorted.each_with_index do |account, i| %>
                <% c = color_cycle[i % color_cycle.length] %>
                <li class="flex items-center justify-between">
                  <div class="flex items-center space-x-2">
                    <span class="w-6 h-6 rounded-md bg-<%= c %>-100 dark:bg-<%= c %>-900/30 flex items-center justify-center">
                      <svg class="w-3.5 h-3.5 text-<%= c %>-600 dark:text-<%= c %>-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                      </svg>
                    </span>
                    <span class="text-sm text-gray-700 dark:text-gray-300"><%= account.name %></span>
                  </div>
                  <span class="text-sm font-semibold text-gray-900 dark:text-white tabular-nums"><%= number_to_currency(account.balance.to_f) %></span>
                </li>
              <% end %>
            </ul>
            <div class="flex items-center justify-between mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Total Assets</span>
              <span class="text-xs font-semibold text-green-600 dark:text-green-400 tabular-nums"><%= number_to_currency(assets_sum) %></span>
            </div>
          <% else %>
            <p class="text-xs text-gray-400 dark:text-gray-500 ml-1">No asset accounts.</p>
          <% end %>
        </div>
        <%# --- Liabilities Section --- %>
        <div>
          <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1.5">Liabilities</p>
          <% if liability_accounts_sorted.any? %>
            <ul class="space-y-1.5">
              <% liability_accounts_sorted.each_with_index do |account, i| %>
                <% c = color_cycle[(asset_accounts_sorted.length + i) % color_cycle.length] %>
                <li class="flex items-center justify-between">
                  <div class="flex items-center space-x-2">
                    <span class="w-6 h-6 rounded-md bg-red-100 dark:bg-red-900/30 flex items-center justify-center">
                      <svg class="w-3.5 h-3.5 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                      </svg>
                    </span>
                    <span class="text-sm text-gray-700 dark:text-gray-300"><%= account.name %></span>
                  </div>
                  <span class="text-sm font-semibold text-red-600 dark:text-red-400 tabular-nums"><%= number_to_currency(-account.balance.to_f.abs) %></span>
                </li>
              <% end %>
            </ul>
            <div class="flex items-center justify-between mt-1.5 pt-1.5 border-t border-gray-100 dark:border-gray-700">
              <span class="text-xs font-semibold text-gray-600 dark:text-gray-400">Total Liabilities</span>
              <span class="text-xs font-semibold text-red-600 dark:text-red-400 tabular-nums"><%= number_to_currency(liabilities_sum) %></span>
            </div>
          <% else %>
            <p class="text-xs text-gray-400 dark:text-gray-500 ml-1">No liability accounts.</p>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCard" aria-label="View assets vs liabilities">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <div class="flex items-center space-x-3">
        <%= link_to accounts_path, class: "text-xs text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300 font-medium" do %>
          Manage Accounts &rsaquo;
        <% end %>
        <button type="button" data-action="click->dashboard#toggleCardExpand"
                data-role="expand-btn"
                class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
                aria-label="Expand Accounts Card">
          <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
          </svg>
          <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  <%# === BACK SIDE (Assets vs Liabilities Comparison) === %>
  <div class="absolute inset-0 flex flex-col" data-role="back" style="backface-visibility: hidden; transform: rotateY(180deg); pointer-events: none;">
    <div data-role="back-content" class="dash-card-scroll">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-sm font-semibold text-gray-800 dark:text-gray-200">Assets vs Liabilities</h2>
        <div class="flex items-center">
          <span class="text-sm font-semibold text-gray-900 dark:text-white tabular-nums">Accounts Total: <%= number_to_currency(card2_total) %></span>
          <%= link_to report_account_balance_history_path, class: "ml-2 text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition", aria: { label: "Open accounts report" } do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18"/><path stroke-linecap="round" stroke-linejoin="round" d="M7 16V9m4 7V5m4 11v-4m4 4V8"/></svg>
          <% end %>
        </div>
      </div>
      <% if bar_total > 0 %>
        <%# --- Horizontal Bar --- %>
        <div class="mb-4">
          <div class="flex h-8 rounded-lg overflow-hidden">
            <% if assets_pct > 0 %>
              <div class="bg-green-500 dark:bg-green-600 flex items-center justify-center" style="width: <%= [assets_pct, 8].max %>%">
                <span class="text-xs font-bold text-white"><%= assets_pct %>%</span>
              </div>
            <% end %>
            <% if liabilities_pct > 0 %>
              <div class="bg-red-500 dark:bg-red-600 flex items-center justify-center" style="width: <%= [liabilities_pct, 8].max %>%">
                <span class="text-xs font-bold text-white"><%= liabilities_pct %>%</span>
              </div>
            <% end %>
          </div>
          <div class="flex items-center justify-between mt-2">
            <span class="text-xs font-semibold text-green-600 dark:text-green-400 tabular-nums">Assets: <%= number_to_currency(assets_sum) %></span>
            <span class="text-xs font-semibold text-red-600 dark:text-red-400 tabular-nums">Liabilities: <%= number_to_currency(liabilities_sum) %></span>
          </div>
        </div>
        <%# --- Top Accounts Breakdown --- %>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Top Assets</p>
            <% if asset_accounts_sorted.any? %>
              <ul class="space-y-1">
                <% asset_accounts_sorted.first(3).each do |account| %>
                  <li class="flex items-center justify-between">
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                    <span class="text-xs font-semibold text-gray-900 dark:text-white tabular-nums flex-shrink-0"><%= number_to_currency(account.balance.to_f) %></span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-xs text-gray-400 dark:text-gray-500">None</p>
            <% end %>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Top Liabilities</p>
            <% if liability_accounts_sorted.any? %>
              <ul class="space-y-1">
                <% liability_accounts_sorted.first(3).each do |account| %>
                  <li class="flex items-center justify-between">
                    <span class="text-xs text-gray-700 dark:text-gray-300 truncate mr-1"><%= account.name %></span>
                    <span class="text-xs font-semibold text-red-600 dark:text-red-400 tabular-nums flex-shrink-0"><%= number_to_currency(account.balance.to_f.abs) %></span>
                  </li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-xs text-gray-400 dark:text-gray-500">None</p>
            <% end %>
          </div>
        </div>
      <% else %>
        <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-8">No account data available.</p>
      <% end %>
    </div>
    <div class="dash-card-footer border-t border-gray-100 dark:border-gray-700 flex items-center justify-between" data-role="card-footer">
      <button type="button" class="inline-flex items-center justify-center text-brand-600 dark:text-brand-400 hover:text-brand-700 dark:hover:text-brand-300" style="min-width:44px; min-height:44px;" data-action="click->dashboard#flipCardBack" aria-label="Back to accounts list">
        <svg class="w-[18px] h-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.992 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M20.015 4.652v4.992"/>
        </svg>
      </button>
      <button type="button" data-action="click->dashboard#toggleCardExpand"
              data-role="expand-btn"
              class="inline-flex items-center justify-center text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition cursor-pointer" style="min-width:44px; min-height:44px;"
              aria-label="Expand Accounts Card">
        <svg class="w-[18px] h-[18px]" data-icon="expand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"/>
        </svg>
        <svg class="w-[18px] h-[18px] hidden" data-icon="collapse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"/>
        </svg>
      </button>
    </div>
  </div>
</div>
