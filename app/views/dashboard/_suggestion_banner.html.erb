<% if @top_suggestion&.feature_block %>
  <div class="mb-6 bg-brand-50 dark:bg-brand-900/20 border-l-4 border-brand-600 rounded-r-lg p-4 flex items-start space-x-3"
       data-controller="suggestion-banner"
       data-suggestion-banner-dismiss-url-value="<%= api_smart_suggestion_dismiss_path(@top_suggestion.id) %>"
       data-suggestion-banner-csrf-token-value="<%= form_authenticity_token %>"
       data-suggestion-banner-target="banner">
    <%# Lightbulb icon %>
    <svg class="h-5 w-5 text-brand-600 dark:text-brand-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
    </svg>
    <div class="flex-1 min-w-0">
      <p class="text-sm text-gray-700 dark:text-gray-300">
        <%= @top_suggestion.reason_text %>
      </p>
      <div class="mt-2">
        <a href="<%= feature_store_path %>" class="inline-flex items-center px-3 py-1.5 text-xs font-medium text-white bg-brand-600 rounded-lg hover:bg-brand-700 transition">
          Activate <%= @top_suggestion.feature_block.display_name %>
        </a>
      </div>
    </div>
    <%# Dismiss button %>
    <button type="button"
            class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition flex-shrink-0"
            data-action="click->suggestion-banner#dismiss">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
<% end %>
