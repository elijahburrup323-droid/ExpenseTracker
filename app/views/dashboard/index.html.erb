<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4"
     data-controller="dashboard"
     data-dashboard-api-url-value="<%= api_dashboard_card_data_path %>"
     data-dashboard-recent-activity-url-value="<%= api_dashboard_recent_activity_page_path %>"
     data-dashboard-reorder-url-value="<%= api_dashboard_reorder_slots_path %>"
     data-dashboard-open-month-url-value="<%= api_open_month_master_path %>"
     data-dashboard-month-value="<%= @open_month.current_month %>"
     data-dashboard-year-value="<%= @open_month.current_year %>"
     data-dashboard-earliest-month-value="<%= @earliest[:month] %>"
     data-dashboard-earliest-year-value="<%= @earliest[:year] %>">

  <% if @show_first_login_wizard %>
    <%= render "dashboard/first_login_wizard" %>
  <% end %>

  <%# Smart Suggestion Banner %>
  <div data-tutorial="dashboard-quote"><%= render "dashboard/suggestion_banner" %></div>

  <% if @tutorial_available %>
    <div class="flex items-center mb-4">
      <a href="<%= request.path %>?start_tutorial=1" class="inline-flex items-center px-2.5 py-1 text-xs font-medium text-brand-600 bg-brand-50 rounded-lg hover:bg-brand-100 transition">
        <svg class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        Tour
      </a>
    </div>
  <% end %>

  <%# Financial Pulse strip — colored metric pills %>
  <%
    # Determine Cash Runway color state
    if @pulse_liquidity
      if @pulse_liquidity >= 3.0
        runway_color = "emerald"
      elsif @pulse_liquidity >= 1.0
        runway_color = "amber"
      else
        runway_color = "red"
      end
    end

    # Determine Debt Ratio color state
    if @pulse_debt_ratio
      if @pulse_debt_ratio < 36
        debt_color = "emerald"
      elsif @pulse_debt_ratio < 50
        debt_color = "amber"
      else
        debt_color = "red"
      end
    end

    # Determine Savings Rate color state
    if @pulse_savings_rate
      if @pulse_savings_rate >= 20
        savings_color = "emerald"
      elsif @pulse_savings_rate >= 5
        savings_color = "amber"
      else
        savings_color = "red"
      end
    end
  %>
  <div class="flex flex-col gap-1.5 mb-3 px-1" data-dashboard-target="pulseStrip">
    <span class="font-semibold text-gray-600 dark:text-gray-300 uppercase tracking-wider" style="font-size: 10px;">Financial Pulse</span>
    <div class="flex flex-wrap gap-2">
      <% if @pulse_liquidity %>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border bg-<%= runway_color %>-50 dark:bg-<%= runway_color %>-900/20 border-<%= runway_color %>-200 dark:border-<%= runway_color %>-800 text-<%= runway_color %>-700 dark:text-<%= runway_color %>-400 text-xs flex-1 min-w-[140px]">
          <span class="flex-shrink-0">&#x1f6e1;</span>
          <span class="font-medium">Cash Runway</span>
          <span class="ml-auto tabular-nums font-semibold"><%= @pulse_liquidity %> mo</span>
          <span class="text-<%= runway_color %>-400 dark:text-<%= runway_color %>-500 cursor-help" title="How many months your cash accounts could cover your average monthly spending. Healthy: 3+ months.">&#9432;</span>
        </div>
      <% end %>
      <% if @pulse_debt_ratio %>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border bg-<%= debt_color %>-50 dark:bg-<%= debt_color %>-900/20 border-<%= debt_color %>-200 dark:border-<%= debt_color %>-800 text-<%= debt_color %>-700 dark:text-<%= debt_color %>-400 text-xs flex-1 min-w-[140px]">
          <span class="flex-shrink-0">&#x1f4ca;</span>
          <span class="font-medium">Debt Ratio</span>
          <span class="ml-auto tabular-nums font-semibold"><%= @pulse_debt_ratio %>%</span>
          <span class="text-<%= debt_color %>-400 dark:text-<%= debt_color %>-500 cursor-help" title="Your total liabilities divided by total assets. Below 36% is healthy; above 50% is high risk.">&#9432;</span>
        </div>
      <% elsif @net_worth_assets == 0 %>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border bg-gray-50 dark:bg-gray-800 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 text-xs flex-1 min-w-[140px]">
          <span class="flex-shrink-0">&#x1f4ca;</span>
          <span class="font-medium">Debt Ratio</span>
          <span class="ml-auto tabular-nums font-semibold">&mdash;</span>
          <span class="text-gray-400 dark:text-gray-500 cursor-help" title="Your total liabilities divided by total assets. Below 36% is healthy; above 50% is high risk.">&#9432;</span>
        </div>
      <% end %>
      <% if @pulse_savings_rate %>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border bg-<%= savings_color %>-50 dark:bg-<%= savings_color %>-900/20 border-<%= savings_color %>-200 dark:border-<%= savings_color %>-800 text-<%= savings_color %>-700 dark:text-<%= savings_color %>-400 text-xs flex-1 min-w-[140px]">
          <span class="flex-shrink-0">&#x1f331;</span>
          <span class="font-medium">Savings Rate</span>
          <span class="ml-auto tabular-nums font-semibold"><%= @pulse_savings_rate %>%</span>
          <span class="text-<%= savings_color %>-400 dark:text-<%= savings_color %>-500 cursor-help" title="Percentage of your income that went toward savings or reduced debt this month. Target: 20%+.">&#9432;</span>
        </div>
      <% else %>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border bg-gray-50 dark:bg-gray-800 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 text-xs flex-1 min-w-[140px]">
          <span class="flex-shrink-0">&#x1f331;</span>
          <span class="font-medium">Savings Rate</span>
          <span class="ml-auto tabular-nums font-semibold">&mdash;</span>
          <span class="text-gray-400 dark:text-gray-500 cursor-help" title="Percentage of your income that went toward savings or reduced debt this month. Target: 20%+.">&#9432;</span>
        </div>
      <% end %>
    </div>
  </div>

  <%# ===== 6-CARD GRID (3 x 2, equal size) ===== %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 md:dash-grid gap-3 md:gap-5" data-dashboard-target="cardsGrid" data-tutorial="dashboard-cards">

    <% @slots.each do |slot| %>
      <% card = slot.dashboard_card %>
      <% next unless card&.is_active %>
      <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-3 lg:p-5 dash-card min-w-0"
           style="perspective: 1000px;"
           data-dashboard-target="slotWrapper"
           data-slot-number="<%= slot.slot_number %>"
           data-card-type="<%= card.card_type %>"
           data-card-key="<%= card.card_key %>">
        <%= render partial: "dashboard/cards/#{card.card_type}",
                   locals: { slot: slot, card: card } %>
      </div>
    <% end %>

  </div>
</div>
