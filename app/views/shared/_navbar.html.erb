<%# Mobile hamburger button (fixed, visible only on small screens) %>
<button type="button"
        class="md:hidden fixed top-3 left-3 z-50 p-2 rounded-lg bg-brand-600 text-white shadow-lg hover:bg-brand-700 transition"
        data-action="click->sidebar#openMobile">
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
  </svg>
</button>

<%# Backdrop for mobile sidebar %>
<div class="hidden fixed inset-0 bg-black/50 z-40 md:hidden"
     data-sidebar-target="backdrop"
     data-action="click->sidebar#closeMobile"></div>

<%# Sidebar %>
<aside class="fixed top-0 left-0 z-40 bg-gradient-to-b from-brand-700 via-brand-600 to-brand-500 shadow-lg flex flex-col transition-all duration-300 w-56 -translate-x-full md:translate-x-0" style="height: 100vh; height: 100dvh;"
       data-sidebar-target="sidebar"
       data-collapsed="false">

  <%# Logo %>
  <div class="flex items-center h-14 px-4 border-b border-white/20">
    <%= link_to dashboard_path, class: "flex items-center space-x-2 min-w-0",
        onclick: "if(window.location.pathname==='/dashboard'){sessionStorage.setItem('bhDashReset','1')}" do %>
      <div class="relative flex-shrink-0">
        <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3z"/>
        </svg>
        <% if ENV["DEPLOY_ENV"] == "uat" %>
          <span class="absolute -top-1.5 -right-2.5 bg-red-600 text-white text-[8px] font-black leading-none px-1 py-0.5 rounded shadow-md ring-1 ring-red-400/50">QA</span>
        <% end %>
      </div>
      <span class="text-lg font-bold text-white tracking-tight truncate" data-sidebar-label>MyBudgetHQ</span>
    <% end %>
  </div>

  <%# Navigation links %>
  <nav class="flex-1 overflow-y-auto py-3 px-2 space-y-1" data-tutorial="dashboard-nav">
    <%
      nav_groups = [
        {
          heading: "Accounts",
          path: accounts_path,
          feature_block: nil,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2 7a2 2 0 012-2h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V7zm10 3a2 2 0 100 4 2 2 0 000-4zm-6 2h.01M18 12h.01"/>',
          children: [
            { path: account_types_path, label: "Account Types", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>' },
            { path: transfer_masters_path, label: "Transfers", feature_block: "transfers", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>' },
            { path: account_reconciliation_path, label: "Reconciliation", feature_block: "reconciliation", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
            { path: buckets_path, label: "Buckets", feature_block: "buckets", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>' },
            { path: smart_import_path, label: "Smart Import", feature_block: "smart_import", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>' },
          ],
        },
        {
          heading: "Assets",
          path: assets_path,
          feature_block: "assets",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/>',
          children: [
            { path: assets_path, label: "Assets Dashboard", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>' },
            { path: assets_list_path, label: "Assets List", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>' },
          ],
        },
        {
          heading: "Investments",
          path: investments_path,
          feature_block: "investments",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>',
          children: [
            { path: investments_path, label: "Investments Dashboard", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>' },
            { path: investment_accounts_path, label: "Investment Accounts", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2 7a2 2 0 012-2h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V7zm10 3a2 2 0 100 4 2 2 0 000-4zm-6 2h.01M18 12h.01"/>' },
          ],
        },
        {
          heading: "Financing",
          path: financing_loans_notes_path,
          feature_block: "financing",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/>',
          children: [
            { path: financing_loans_notes_path, label: "Loans & Notes", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>' },
            { path: financing_contracts_for_deed_path, label: "Contracts for Deed", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>' },
          ],
        },
        {
          heading: "Deposits",
          path: income_entries_path,
          feature_block: "income_tracking",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>',
          children: [
            { path: income_user_frequencies_path, label: "Frequencies", feature_block: "recurring_income", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>' },
          ],
        },
        {
          heading: "Payments",
          path: payments_path,
          feature_block: "payments_basic",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a5 5 0 00-10 0v2M12 12v3m-3-3h6m-9 7h12a2 2 0 002-2v-4a2 2 0 00-2-2H6a2 2 0 00-2 2v4a2 2 0 002 2z"/>',
          children: [
            { path: spending_categories_path, label: "Categories", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>' },
            { path: spending_types_path, label: "Spending Types", feature_block: nil, icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>' },
            { path: tags_path, label: "Tags", feature_block: "tags", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z"/>' },
          ],
        },
        {
          heading: "Monthly",
          path: soft_close_path,
          feature_block: "monthly_close",
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>',
          children: [
            { path: reports_path, label: "Reports", feature_block: "reports", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>' },
            { path: soft_close_path, label: "Soft Close Month", feature_block: "monthly_close", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>' },
          ]
        },
      ]

      # Progressive Feature Disclosure: filter sidebar by global killswitch + user feature blocks
      active_keys = current_user.active_feature_block_keys
      global_flags = { "assets" => (defined?(FEATURE_ASSETS_ENABLED) ? FEATURE_ASSETS_ENABLED : true),
                       "investments" => (defined?(FEATURE_INVESTMENTS_ENABLED) ? FEATURE_INVESTMENTS_ENABLED : true),
                       "financing" => (defined?(FEATURE_FINANCING_ENABLED) ? FEATURE_FINANCING_ENABLED : true) }

      nav_groups = nav_groups.map do |group|
        fb = group[:feature_block]
        # Hide if global killswitch is off or user doesn't have the feature
        if fb.present? && (global_flags[fb] == false || !active_keys.include?(fb))
          next nil
        end
        # Filter children by the same rules
        filtered_children = group[:children].select do |child|
          cfb = child[:feature_block]
          cfb.nil? || (global_flags.fetch(cfb, true) != false && active_keys.include?(cfb))
        end
        group.merge(children: filtered_children)
      end.compact

      if current_user.budgethq_agent?
        nav_groups << {
          heading: "Admin",
          path: admin_users_path,
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>',
          children: [
            { path: dbu_path, label: "DBU", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>' },
            { path: diagnostics_path, label: "Diagnostics", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>' },
            { path: documentation_path, label: "Documentation", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>' },
            { path: quotes_path, label: "Quotes", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>' },
            { path: income_frequency_masters_path, label: "Frequency Masters", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>' },
            { path: account_type_masters_path, label: "Acct Type Masters", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>' },
            { path: reports_masters_path, label: "Reports Maint.", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>' },
            { path: legal_pages_admin_path("terms"), label: "Terms Maint.", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>' },
            { path: legal_pages_admin_path("privacy"), label: "Privacy Maint.", icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>' },
          ]
        }
      end
    %>

    <%# Grouped sections %>
    <% nav_groups.each do |group| %>
      <% group_key = group[:heading].parameterize %>
      <% active = current_page?(group[:path]) %>
      <% flash_group = params[:flash_sidebar] == "1" && current_page?(group[:path]) %>

      <%# Group heading row: link + chevron toggle %>
      <div class="flex items-center">
        <a href="<%= group[:path] %>"
           class="group relative flex-1 flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-semibold transition <%= active ? 'bg-white/20 text-white' : 'text-white/90 hover:bg-white/10 hover:text-white' %> <%= 'sidebar-flash-pulse' if flash_group %>"
           data-tooltip="<%= group[:heading] %>"
           data-group="<%= group_key %>"
           data-action="mouseenter->sidebar#showTooltip mouseleave->sidebar#hideTooltip click->sidebar#handleGroupClick">
          <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <%= group[:icon].html_safe %>
          </svg>
          <span data-sidebar-label class="truncate"><%= group[:heading] %></span>
        </a>
        <button type="button"
                class="p-1 text-white/60 hover:text-white transition"
                data-sidebar-label
                data-action="click->sidebar#toggleGroup"
                data-group="<%= group_key %>"
                title="Toggle <%= group[:heading] %>">
          <svg class="h-4 w-4 transition-transform duration-200" data-sidebar-chevron="<%= group_key %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
      </div>

      <%# Collapsible child links %>
      <div data-sidebar-group="<%= group_key %>" class="overflow-hidden transition-all duration-200">
        <% group[:children].each do |link| %>
          <% child_active = current_page?(link[:path]) %>
          <% flash_child = params[:flash_sidebar] == "1" && current_page?(link[:path]) %>
          <a href="<%= link[:path] %>"
             class="group relative flex items-center space-x-3 pl-6 pr-3 py-1.5 rounded-lg text-sm font-medium transition <%= child_active ? 'bg-white/20 text-white' : 'text-white/70 hover:bg-white/10 hover:text-white' %> <%= 'sidebar-flash-pulse' if flash_child %>"
             data-tooltip="<%= link[:label] %>"
             data-action="mouseenter->sidebar#showTooltip mouseleave->sidebar#hideTooltip">
            <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <%= link[:icon].html_safe %>
            </svg>
            <span data-sidebar-label class="truncate"><%= link[:label] %></span>
          </a>
        <% end %>

        <%# Sub-groups (e.g. Month) %>
        <% (group[:subgroups] || []).each do |subgroup| %>
          <% sub_key = "#{group_key}-#{subgroup[:label].parameterize}" %>

          <%# Sub-group heading with toggle %>
          <div class="flex items-center mt-1">
            <div class="flex-1 flex items-center space-x-2 pl-6 pr-3 py-1 text-xs font-semibold text-white/50 uppercase tracking-wider">
              <svg class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <%= subgroup[:icon].html_safe %>
              </svg>
              <span data-sidebar-label><%= subgroup[:label] %></span>
            </div>
            <button type="button"
                    class="p-1 text-white/40 hover:text-white/70 transition"
                    data-sidebar-label
                    data-action="click->sidebar#toggleGroup"
                    data-group="<%= sub_key %>"
                    title="Toggle <%= subgroup[:label] %>">
              <svg class="h-3.5 w-3.5 transition-transform duration-200" data-sidebar-chevron="<%= sub_key %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
          </div>

          <%# Sub-group children %>
          <div data-sidebar-group="<%= sub_key %>" class="overflow-hidden transition-all duration-200">
            <% subgroup[:children].each do |link| %>
              <% child_active = current_page?(link[:path]) %>
              <a href="<%= link[:path] %>"
                 class="group relative flex items-center space-x-3 pl-10 pr-3 py-1.5 rounded-lg text-sm font-medium transition <%= child_active ? 'bg-white/20 text-white' : 'text-white/70 hover:bg-white/10 hover:text-white' %>"
                 data-tooltip="<%= link[:label] %>"
                 data-action="mouseenter->sidebar#showTooltip mouseleave->sidebar#hideTooltip">
                <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <%= link[:icon].html_safe %>
                </svg>
                <span data-sidebar-label class="truncate"><%= link[:label] %></span>
              </a>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="my-1"></div>
    <% end %>

    <%# Explore More Features %>
    <div class="mt-2 px-1">
      <a href="<%= feature_store_path %>"
         class="group relative flex items-center space-x-3 px-3 py-2 rounded-lg text-sm font-medium transition text-yellow-300/90 hover:bg-white/10 hover:text-yellow-200 border border-yellow-300/20 hover:border-yellow-300/40"
         data-tooltip="Feature Store"
         data-action="mouseenter->sidebar#showTooltip mouseleave->sidebar#hideTooltip">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        <span data-sidebar-label class="truncate">Feature Store</span>
      </a>
    </div>
  </nav>


  <%# Bottom profile section — click name to expand/collapse %>
  <div class="border-t border-white/20 px-2 py-3" data-controller="dropdown">
    <%# User name + collapse toggle row %>
    <div class="flex items-center">
      <%# User name button — toggles the dropdown menu %>
      <button type="button"
              class="flex-1 flex items-center space-x-3 px-3 py-1.5 text-white/80 hover:bg-white/10 rounded-lg transition min-w-0"
              data-action="click->dropdown#toggle">
        <div class="h-6 w-6 rounded-full bg-white/20 flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
          <%= current_user.first_name&.first&.upcase || current_user.email.first.upcase %>
        </div>
        <span data-sidebar-label class="text-sm font-medium truncate"><%= current_user.first_name || current_user.email %></span>
        <svg class="h-4 w-4 text-white/50 ml-auto flex-shrink-0" data-sidebar-label fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
      </button>
      <%# Collapse/Expand sidebar toggle — next to profile name %>
      <button type="button"
              class="hidden md:flex items-center justify-center w-7 h-7 rounded-full bg-white/10 text-white/70 hover:bg-white/20 hover:text-white transition ml-1 flex-shrink-0"
              data-action="click->sidebar#toggle"
              title="Toggle sidebar">
        <svg class="h-3.5 w-3.5 transition-transform duration-300" data-sidebar-target="toggleIcon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>
    </div>
    <%# Collapsible menu items %>
    <div class="hidden mt-1 space-y-1" data-dropdown-target="menu">
      <%# Theme toggle %>
      <div data-controller="theme">
        <button type="button"
                class="w-full flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:bg-white/10 hover:text-white transition"
                data-action="click->theme#toggle">
          <svg data-theme-target="moonIcon" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
          </svg>
          <svg data-theme-target="sunIcon" class="h-4 w-4 flex-shrink-0 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
          <span data-sidebar-label>Theme</span>
        </button>
      </div>
      <%# Theme Settings %>
      <%= link_to theme_settings_path, class: "flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:bg-white/10 hover:text-white transition" do %>
        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
        </svg>
        <span data-sidebar-label>Theme Settings</span>
      <% end %>
      <%# Settings %>
      <%= link_to edit_user_registration_path, class: "flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:bg-white/10 hover:text-white transition" do %>
        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        <span data-sidebar-label>Settings</span>
      <% end %>
      <%# Social Security Benefit Planner %>
      <%= link_to social_security_planner_path, class: "flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:bg-white/10 hover:text-white transition" do %>
        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        <span data-sidebar-label>SS Benefit Planner</span>
      <% end %>
      <%# Upgrade %>
      <%= link_to pricing_path, class: "flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-yellow-300 hover:bg-white/10 hover:text-yellow-200 transition" do %>
        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 3l7 4 7-4v11a2 2 0 01-1.03 1.75L12 19l-5.97-3.25A2 2 0 015 14V3z"/>
        </svg>
        <span data-sidebar-label>Upgrade</span>
      <% end %>
      <%# Sign out — clear dashboard sessionStorage to prevent cross-user leakage %>
      <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center space-x-3 px-3 py-1.5 rounded-lg text-sm text-white/70 hover:bg-white/10 hover:text-white transition",
          onclick: "Object.keys(sessionStorage).filter(k=>k.startsWith('bhDash')).forEach(k=>sessionStorage.removeItem(k))" do %>
        <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        <span data-sidebar-label>Sign Out</span>
      <% end %>
    </div>
  </div>

  <%# Tooltip (positioned via JS, outside nav overflow) %>
  <div data-sidebar-target="tooltip"
       class="hidden fixed z-50 px-2.5 py-1.5 rounded-md bg-gray-900 text-white text-xs whitespace-nowrap shadow-lg pointer-events-none"></div>

  <%# Flyout for collapsed group children (positioned via JS) %>
  <div data-sidebar-target="flyout"
       class="hidden fixed z-50 py-2 rounded-lg bg-gray-900 shadow-xl min-w-[10rem]"
       data-action="mouseleave->sidebar#hideFlyout"></div>
</aside>
