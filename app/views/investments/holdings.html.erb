<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="investment-holdings"
     data-investment-holdings-api-url-value="<%= api_investment_holdings_path %>"
     data-investment-holdings-account-id-value="<%= @account.id %>"
     data-investment-holdings-detail-base-url-value="/investments/holding"
     data-investment-holdings-csrf-token-value="<%= form_authenticity_token %>">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-center space-x-3 mb-1">
          <a href="<%= investments_path %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @account.name %></h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              Holdings Overview
              <span class="ml-2 text-xs text-gray-400 dark:text-gray-500" data-investment-holdings-target="total"></span>
            </p>
          </div>
        </div>
      </div>
      <div class="flex items-center space-x-2">
        <div class="relative group">
          <button type="button" disabled
                  class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 opacity-50 cursor-not-allowed">
            <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            Add Transaction
          </button>
          <div class="hidden group-hover:block absolute right-0 top-full mt-1 z-30">
            <p class="text-xs text-white bg-gray-900 dark:bg-gray-700 rounded px-2 py-1 whitespace-nowrap shadow-lg">Coming in CM-10</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Data Table %>
  <div class="mt-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="ticker_symbol" data-action="click->investment-holdings#toggleSort">
              Symbol <span data-sort-icon="ticker_symbol" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="security_name" data-action="click->investment-holdings#toggleSort">
              Description <span data-sort-icon="security_name" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="shares_held" data-action="click->investment-holdings#toggleSort">
              Total Shares <span data-sort-icon="shares_held" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="current_price" data-action="click->investment-holdings#toggleSort">
              Market Price <span data-sort-icon="current_price" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="market_value" data-action="click->investment-holdings#toggleSort">
              Market Value <span data-sort-icon="market_value" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="cost_basis" data-action="click->investment-holdings#toggleSort">
              Cost Basis <span data-sort-icon="cost_basis" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="unrealized_gain" data-action="click->investment-holdings#toggleSort">
              Unrealized Gain <span data-sort-icon="unrealized_gain" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="gain_pct" data-action="click->investment-holdings#toggleSort">
              % Gain/Loss <span data-sort-icon="gain_pct" class="ml-1 text-gray-400"></span>
            </th>
          </tr>
        </thead>
        <tbody data-investment-holdings-target="tableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
          <tr><td colspan="8" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
