<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="investment-transactions"
     data-investment-transactions-api-url-value="<%= api_investment_transactions_path %>"
     data-investment-transactions-holdings-api-url-value="<%= api_investment_holdings_path %>"
     data-investment-transactions-account-id-value="<%= @account.id %>"
     data-investment-transactions-holdings-base-url-value="<%= investment_holdings_path(@account.id) %>"
     data-investment-transactions-csrf-token-value="<%= form_authenticity_token %>">

  <%# ===== Page Header (sticky) ===== %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-center space-x-3 mb-1">
          <a href="<%= investment_holdings_path(@account.id) %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <div>
            <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @account.name %></h1>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
              Add / Manage Investment Transactions
              <span class="ml-2 text-xs text-gray-400 dark:text-gray-500" data-investment-transactions-target="total"></span>
            </p>
          </div>
        </div>
      </div>
      <div class="flex items-center space-x-2">
        <select data-investment-transactions-target="holdingFilter"
                data-action="change->investment-transactions#filterByHolding"
                class="text-sm border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500">
          <option value="">All Holdings</option>
        </select>
        <button type="button" data-action="click->investment-transactions#startAdding"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 transition">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Transaction
        </button>
      </div>
    </div>
  </div>

  <%# ===== Transaction Form Panel (hidden by default) ===== %>
  <div data-investment-transactions-target="formPanel" class="hidden mt-4 mb-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white" data-investment-transactions-target="formTitle">Add Transaction</h2>
        <button type="button" data-action="click->investment-transactions#cancelForm"
                class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <%# Error banner %>
      <div data-investment-transactions-target="formError"
           class="hidden mb-4 p-3 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg text-sm text-red-700 dark:text-red-400"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <%# Transaction Type %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Transaction Type</label>
          <select data-investment-transactions-target="fieldType"
                  data-action="change->investment-transactions#typeChanged"
                  class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="">Select type...</option>
            <option value="BUY">BUY</option>
            <option value="SELL">SELL</option>
            <option value="DIVIDEND">DIVIDEND</option>
            <option value="REINVEST">REINVEST</option>
            <option value="FEE">FEE</option>
          </select>
        </div>

        <%# Holding %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Holding</label>
          <select data-investment-transactions-target="fieldHolding"
                  data-action="change->investment-transactions#fieldChanged"
                  class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="">Select holding...</option>
          </select>
        </div>

        <%# Trade Date %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Trade Date</label>
          <input type="date" data-investment-transactions-target="fieldDate"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>

        <%# Quantity (shares) — shown for BUY/SELL/REINVEST %>
        <div data-investment-transactions-target="sharesGroup">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Quantity (Shares)</label>
          <input type="number" step="any" min="0" data-investment-transactions-target="fieldShares"
                 data-action="input->investment-transactions#fieldChanged"
                 placeholder="0"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums">
        </div>

        <%# Price — shown for BUY/SELL/REINVEST %>
        <div data-investment-transactions-target="priceGroup">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Price per Share</label>
          <input type="number" step="any" min="0" data-investment-transactions-target="fieldPrice"
                 data-action="input->investment-transactions#fieldChanged"
                 placeholder="0.00"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums">
        </div>

        <%# Amount %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Amount</label>
          <input type="number" step="any" min="0" data-investment-transactions-target="fieldAmount"
                 data-action="input->investment-transactions#fieldChanged"
                 placeholder="0.00"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums">
        </div>

        <%# Fees %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Fees</label>
          <input type="number" step="any" min="0" data-investment-transactions-target="fieldFees"
                 placeholder="0.00"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 tabular-nums">
        </div>

        <%# Notes %>
        <div class="sm:col-span-2 lg:col-span-1">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
          <input type="text" data-investment-transactions-target="fieldNotes" maxlength="500"
                 placeholder="Optional"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
        </div>
      </div>

      <%# Realized Gain Preview (SELL only) %>
      <div data-investment-transactions-target="realizedGainPreview" class="hidden mt-4 p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg">
        <span class="text-sm text-gray-600 dark:text-gray-300">Estimated Realized Gain: </span>
        <span data-investment-transactions-target="realizedGainValue" class="text-sm"></span>
      </div>

      <%# Save / Cancel buttons %>
      <div class="flex items-center justify-end space-x-3 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700">
        <button type="button" data-action="click->investment-transactions#cancelForm"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition">
          Cancel
        </button>
        <button type="button" data-investment-transactions-target="formSaveBtn"
                data-action="click->investment-transactions#saveForm"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition">
          Save Transaction
        </button>
      </div>
    </div>
  </div>

  <%# ===== Transaction History Table ===== %>
  <div class="mt-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="transaction_date" data-action="click->investment-transactions#toggleSort">
              Trade Date <span data-sort-icon="transaction_date" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="transaction_type" data-action="click->investment-transactions#toggleSort">
              Type <span data-sort-icon="transaction_type" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="ticker_symbol" data-action="click->investment-transactions#toggleSort">
              Symbol <span data-sort-icon="ticker_symbol" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="shares" data-action="click->investment-transactions#toggleSort">
              Quantity <span data-sort-icon="shares" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="price_per_share" data-action="click->investment-transactions#toggleSort">
              Price <span data-sort-icon="price_per_share" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="total_amount" data-action="click->investment-transactions#toggleSort">
              Amount <span data-sort-icon="total_amount" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none hover:text-gray-700 dark:hover:text-gray-300"
                data-sort-field="realized_gain" data-action="click->investment-transactions#toggleSort">
              Realized Gain <span data-sort-icon="realized_gain" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody data-investment-transactions-target="tableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
          <tr><td colspan="9" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <%# ===== Delete Confirmation Modal ===== %>
  <div data-investment-transactions-target="deleteModal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 p-6 max-w-sm mx-4 w-full">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Delete Transaction</h3>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Are you sure you want to delete this transaction?</p>
      <p class="text-sm font-medium text-gray-900 dark:text-white mb-4" data-investment-transactions-target="deleteModalInfo"></p>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4">This will recalculate all affected holdings and FIFO cost basis.</p>
      <div class="flex items-center justify-end space-x-3">
        <button type="button" data-action="click->investment-transactions#cancelDelete"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600 transition">
          Cancel
        </button>
        <button type="button" data-action="click->investment-transactions#executeDelete"
                class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg shadow-sm transition">
          Delete
        </button>
      </div>
    </div>
  </div>
</div>
