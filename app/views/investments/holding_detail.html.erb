<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="holding-detail"
     data-holding-detail-holding-id-value="<%= @holding.id %>"
     data-holding-detail-api-url-value="<%= api_investment_holdings_path %>"
     data-holding-detail-account-url-value="<%= investment_holdings_path(@holding.investment_account_id) %>"
     data-holding-detail-csrf-token-value="<%= form_authenticity_token %>">

  <%# ===== Page Header (sticky) ===== %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <div class="flex items-center space-x-3 mb-1">
          <a href="<%= investment_holdings_path(@holding.investment_account_id) %>" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white" data-holding-detail-target="headerSymbol"><%= @holding.ticker_symbol.presence || @holding.security_name %></h1>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 ml-8" data-holding-detail-target="headerName"><%= @holding.security_name %></p>
      </div>
      <div class="flex items-center space-x-2">
        <a href="<%= investment_transactions_path(@holding.investment_account_id) %>"
           class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 transition">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Transaction
        </a>
      </div>
    </div>
  </div>

  <%# ===== Summary Metric Cards ===== %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Total Shares</p>
      <p class="mt-2 text-2xl font-bold text-gray-900 dark:text-white tabular-nums" data-holding-detail-target="metricShares">--</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Market Value</p>
      <p class="mt-2 text-2xl font-bold text-gray-900 dark:text-white tabular-nums" data-holding-detail-target="metricMV">--</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Cost Basis</p>
      <p class="mt-2 text-2xl font-bold text-gray-900 dark:text-white tabular-nums" data-holding-detail-target="metricCB">--</p>
    </div>
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 text-center">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Unrealized Gain/Loss</p>
      <p class="mt-2 text-2xl font-bold tabular-nums" data-holding-detail-target="metricUG">--</p>
    </div>
  </div>

  <%# ===== Tab Navigation ===== %>
  <div class="border-b border-gray-200 dark:border-gray-700 mt-6">
    <nav class="flex space-x-6 -mb-px" aria-label="Tabs">
      <button type="button" data-holding-detail-target="tabBtn" data-tab="transactions"
              data-action="click->holding-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-brand-600 text-brand-600 dark:border-brand-400 dark:text-brand-400 transition">
        Transactions
      </button>
      <button type="button" data-holding-detail-target="tabBtn" data-tab="performance"
              data-action="click->holding-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Performance
      </button>
      <button type="button" data-holding-detail-target="tabBtn" data-tab="dividends"
              data-action="click->holding-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Dividends
      </button>
      <button type="button" data-holding-detail-target="tabBtn" data-tab="notes"
              data-action="click->holding-detail#switchTab"
              class="pb-3 px-1 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-600 transition">
        Notes
      </button>
    </nav>
  </div>

  <%# ===== Transactions Tab Panel ===== %>
  <div data-holding-detail-target="tabPanel" data-tab="transactions" class="mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Trade Date</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Type</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Quantity</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Price</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Realized Gain</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody data-holding-detail-target="txnTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr><td colspan="7" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ===== Performance Tab Panel ===== %>
  <div data-holding-detail-target="tabPanel" data-tab="performance" class="hidden mt-6">
    <div data-holding-detail-target="perfChart"></div>
  </div>

  <%# ===== Dividends Tab Panel ===== %>
  <div data-holding-detail-target="tabPanel" data-tab="dividends" class="hidden mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
          <thead class="bg-gray-50 dark:bg-gray-700/50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date</th>
              <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
              <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Reinvested</th>
            </tr>
          </thead>
          <tbody data-holding-detail-target="divTableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
            <tr><td colspan="3" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <%# ===== Notes Tab Panel ===== %>
  <div data-holding-detail-target="tabPanel" data-tab="notes" class="hidden mt-6">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 max-w-2xl mx-auto">
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Notes</label>
      <textarea data-holding-detail-target="notesArea"
                data-action="input->holding-detail#notesChanged"
                rows="8" maxlength="1000"
                class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500 resize-y"
                placeholder="Add notes about this holding..."><%= @holding.notes %></textarea>
      <div class="flex items-center justify-end space-x-3 mt-3">
        <span class="text-xs text-gray-400 dark:text-gray-500" data-holding-detail-target="notesStatus"></span>
        <button type="button" data-holding-detail-target="notesSaveBtn"
                data-action="click->holding-detail#saveNotes"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition opacity-50"
                disabled>
          Save Notes
        </button>
      </div>
    </div>
  </div>
</div>
