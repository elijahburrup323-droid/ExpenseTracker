<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="investment-accounts"
     data-investment-accounts-api-url-value="<%= api_investment_accounts_path %>"
     data-investment-accounts-csrf-token-value="<%= form_authenticity_token %>">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 py-4 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="flex items-center space-x-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Investment Accounts</h1>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
            Manage your brokerage and retirement accounts
            <span class="ml-2 text-xs text-gray-400 dark:text-gray-500"
                  data-investment-accounts-target="total"></span>
          </p>
        </div>
      </div>
      <div class="flex items-center space-x-2">
        <%# Type filter dropdown %>
        <select data-investment-accounts-target="typeFilter"
                data-action="change->investment-accounts#filterByType"
                class="text-sm border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-700 dark:text-gray-300 focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
          <option value="">All Types</option>
        </select>
        <button type="button"
                data-investment-accounts-target="addButton"
                data-action="click->investment-accounts#startAdding"
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition">
          <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
          </svg>
          Add Account
        </button>
      </div>
    </div>
  </div>

  <%# Data Table %>
  <div class="mt-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="name" data-action="click->investment-accounts#toggleSort">
              Account Name <span data-sort-icon="name" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="account_type" data-action="click->investment-accounts#toggleSort">
              Account Type <span data-sort-icon="account_type" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="market_value" data-action="click->investment-accounts#toggleSort">
              Market Value <span data-sort-icon="market_value" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="cost_basis" data-action="click->investment-accounts#toggleSort">
              Cost Basis <span data-sort-icon="cost_basis" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="unrealized_gain" data-action="click->investment-accounts#toggleSort">
              Unrealized Gain <span data-sort-icon="unrealized_gain" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider cursor-pointer select-none"
                data-sort-field="in_net_worth" data-action="click->investment-accounts#toggleSort">
              Net Worth <span data-sort-icon="in_net_worth" class="ml-1 text-gray-400"></span>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody data-investment-accounts-target="tableBody" class="divide-y divide-gray-200 dark:divide-gray-700">
          <tr><td colspan="7" class="px-6 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <%# Add/Edit Modal %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50"
       data-investment-accounts-target="accountModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-lg w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4"
          data-investment-accounts-target="modalTitle">Add Investment Account</h3>

      <div class="space-y-4">
        <%# Account Name %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account Name <span class="text-red-500">*</span></label>
          <input type="text"
                 data-investment-accounts-target="modalName"
                 maxlength="80"
                 class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500"
                 placeholder="e.g. Fidelity Roth IRA">
        </div>

        <%# Account Type %>
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account Type <span class="text-red-500">*</span></label>
          <select data-investment-accounts-target="modalType"
                  class="w-full border border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-brand-500 focus:border-brand-500">
            <option value="">Select type...</option>
          </select>
        </div>

        <%# Include in Net Worth %>
        <div class="flex items-center justify-between">
          <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Include in Net Worth</label>
          <div data-investment-accounts-target="modalNetWorth"></div>
        </div>

        <%# Error message %>
        <p class="text-sm text-red-600 dark:text-red-400 hidden"
           data-investment-accounts-target="modalError"></p>
      </div>

      <div class="flex justify-end space-x-3 mt-6">
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->investment-accounts#cancelModal">Cancel</button>
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg shadow-sm transition"
                data-action="click->investment-accounts#saveModal">Save</button>
      </div>
    </div>
  </div>

  <%# Delete Confirmation Modal %>
  <div class="hidden fixed inset-0 z-[9999] flex items-center justify-center bg-black/50"
       data-investment-accounts-target="deleteModal">
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl max-w-md w-full mx-4 p-6">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-2">Deactivate Account</h3>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        Are you sure you want to deactivate <strong class="text-gray-900 dark:text-white" data-investment-accounts-target="deleteModalName"></strong>?
        The account will be hidden but historical data is preserved.
      </p>
      <div class="flex justify-end space-x-3">
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition"
                data-action="click->investment-accounts#cancelDelete">Cancel</button>
        <button type="button"
                class="px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg shadow-sm transition"
                data-action="click->investment-accounts#executeDelete">Deactivate</button>
      </div>
    </div>
  </div>
</div>
