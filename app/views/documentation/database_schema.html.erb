      <ul class="text-xs text-gray-600 dark:text-gray-400 font-mono space-y-0.5">
        <li>chk_txn_type_values — txn_type IN ('payment','deposit','transfer')</li>
        <li>chk_payment_rules — payment requires account_id, forbids from/to_account_id</li>
        <li>chk_deposit_rules — deposit requires account_id, forbids from/to_account_id</li>
        <li>chk_transfer_rules — transfer requires from_account_id + to_account_id, forbids account_id</li>
        <li>chk_positive_amount — amount &gt; 0</li>
      </ul>
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mt-3 mb-1">Indexes</p>
      <ul class="text-xs text-gray-600 dark:text-gray-400 font-mono space-y-0.5">
        <li>idx_txns_user_date (user_id, txn_date)</li>
        <li>idx_txns_user_type_date (user_id, txn_type, txn_date)</li>
        <li>idx_txns_user_account_date (user_id, account_id, txn_date)</li>
        <li>idx_txns_user_from_account_date (user_id, from_account_id, txn_date)</li>
        <li>idx_txns_user_to_account_date (user_id, to_account_id, txn_date)</li>
        <li>idx_txns_user_deleted (user_id, deleted_at)</li>
        <li>idx_txns_user_external_id (user_id, external_id) UNIQUE</li>
      </ul>
    </div>
