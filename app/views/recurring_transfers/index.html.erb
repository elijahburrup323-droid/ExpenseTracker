<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="recurring-transfers"
     data-recurring-transfers-api-url-value="<%= api_recurring_transfers_path %>"
     data-recurring-transfers-accounts-url-value="<%= api_accounts_path %>"
     data-recurring-transfers-frequencies-url-value="<%= api_income_user_frequencies_path %>"
     data-recurring-transfers-buckets-url-value="<%= api_buckets_path %>"
     data-recurring-transfers-csrf-token-value="<%= form_authenticity_token %>">

  <%# Page Header (sticky) %>
  <div class="sticky top-14 z-20 bg-gray-50 dark:bg-gray-900 -mx-4 sm:-mx-6 lg:-mx-8 px-4 sm:px-6 lg:px-8 pt-4 pb-0 mb-2 border-b border-gray-200 dark:border-gray-700 shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Recurring Transfers</h1>
      <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage your scheduled recurring transfers between accounts</p>
    </div>
    <div class="flex items-center space-x-2">
      <button type="button"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition disabled:opacity-50 disabled:cursor-not-allowed"
              data-recurring-transfers-target="addButton"
              data-action="click->recurring-transfers#startAdding">
        <svg class="h-4 w-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
        </svg>
        Add Recurring Transfer
      </button>
    </div>
    </div>

    <%# Transfers / Recurring Tabs %>
    <div class="flex space-x-6 mt-3">
      <%= link_to transfer_masters_path, class: "pb-2 text-sm font-medium border-b-2 border-transparent text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 hover:border-gray-300 dark:hover:border-gray-500 transition", data: { turbo_action: "replace" } do %>
        Transfers
      <% end %>
      <%= link_to recurring_transfers_path, class: "pb-2 text-sm font-medium border-b-2 border-brand-600 text-brand-600 dark:text-brand-400 dark:border-brand-400", data: { turbo_action: "replace" } do %>
        Recurring
      <% end %>
    </div>
  </div>

  <%# Table %>
  <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg overflow-hidden ring-1 ring-gray-200 dark:ring-gray-700">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">From</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">To</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Amount</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Frequency</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Next Date</th>
          <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider max-w-[140px]">Memo</th>
          <th scope="col" class="px-4 py-3 text-center text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-16">Active</th>
          <th scope="col" class="px-4 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-28">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700" data-recurring-transfers-target="tableBody">
        <tr>
          <td colspan="8" class="px-4 py-8 text-center text-sm text-gray-400 dark:text-gray-500">Loading...</td>
        </tr>
      </tbody>
    </table>
  </div>

  <%# Info Box %>
  <div class="mt-6 rounded-lg bg-blue-50 dark:bg-blue-900/30 p-4 ring-1 ring-blue-200 dark:ring-blue-800">
    <div class="flex">
      <svg class="h-5 w-5 text-blue-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
      </svg>
      <p class="ml-3 text-sm text-blue-700 dark:text-blue-300">
        Recurring Transfers represent your scheduled fund movements between accounts (savings contributions, loan payments, etc.).
        When the next date arrives, a transfer will be automatically generated on the Transfers screen.
      </p>
    </div>
  </div>

  <%# Add / Edit Recurring Transfer Modal %>
  <div class="hidden fixed inset-0 z-50" data-recurring-transfers-target="entryModal">
    <div class="fixed inset-0 bg-gray-500/75 dark:bg-gray-900/80 transition-opacity"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-lg w-full p-6">
        <h3 class="text-lg font-medium text-gray-900 dark:text-white mb-4" data-recurring-transfers-target="modalTitle">Add Recurring Transfer</h3>

        <div class="space-y-4">
          <%# From Account %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">From Account <span class="text-red-500">*</span></label>
            <select class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                    data-recurring-transfers-target="modalFrom"
                    data-action="change->recurring-transfers#onFromAccountChange keydown->recurring-transfers#handleKeydown">
              <option value="">Select account...</option>
            </select>
          </div>

          <%# From Bucket %>
          <div class="hidden" data-recurring-transfers-target="modalFromBucketRow">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">From Bucket</label>
            <select class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                    data-recurring-transfers-target="modalFromBucket"
                    data-action="keydown->recurring-transfers#handleKeydown">
              <option value="">No bucket (whole account)</option>
            </select>
          </div>

          <%# To Account %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">To Account <span class="text-red-500">*</span></label>
            <select class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                    data-recurring-transfers-target="modalTo"
                    data-action="change->recurring-transfers#onToAccountChange keydown->recurring-transfers#handleKeydown">
              <option value="">Select account...</option>
            </select>
          </div>

          <%# To Bucket %>
          <div class="hidden" data-recurring-transfers-target="modalToBucketRow">
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">To Bucket</label>
            <select class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                    data-recurring-transfers-target="modalToBucket"
                    data-action="keydown->recurring-transfers#handleKeydown">
              <option value="">Default bucket</option>
            </select>
          </div>

          <%# Amount %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Amount <span class="text-red-500">*</span></label>
            <div class="relative">
              <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 dark:text-gray-400 text-sm">$</span>
              <input type="number" step="0.01" placeholder="0.00"
                     class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 pl-7 pr-3 py-2 text-right"
                     data-recurring-transfers-target="modalAmount"
                     data-action="keydown->recurring-transfers#handleKeydown">
            </div>
          </div>

          <%# Frequency %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Frequency <span class="text-red-500">*</span></label>
            <select class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                    data-recurring-transfers-target="modalFrequency">
              <option value="">Select frequency...</option>
            </select>
          </div>

          <%# Next Date %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Next Date <span class="text-red-500">*</span></label>
            <input type="date"
                   class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                   data-recurring-transfers-target="modalNextDate"
                   data-action="keydown->recurring-transfers#handleKeydown">
          </div>

          <%# Memo %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Memo</label>
            <input type="text" maxlength="255" placeholder="Optional memo"
                   class="w-full rounded-md border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white shadow-sm text-sm focus:border-brand-500 focus:ring-brand-500 px-3 py-2"
                   data-recurring-transfers-target="modalMemo"
                   data-action="keydown->recurring-transfers#handleKeydown">
          </div>

          <%# Error Display %>
          <div class="hidden rounded-md bg-red-50 dark:bg-red-900/30 p-3" data-recurring-transfers-target="modalError">
            <p class="text-sm text-red-600 dark:text-red-400"></p>
          </div>
        </div>

        <%# Footer Buttons %>
        <div class="mt-6 flex justify-end space-x-3">
          <button type="button"
                  class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition"
                  data-action="click->recurring-transfers#cancelModal">
            Cancel
          </button>
          <button type="button"
                  class="px-4 py-2 text-sm font-medium text-white bg-green-600 border border-transparent rounded-lg hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition"
                  data-action="click->recurring-transfers#saveModal">
            Save
          </button>
        </div>
      </div>
    </div>
  </div>

  <%# Delete Confirmation Modal %>
  <div class="hidden fixed inset-0 z-50" data-recurring-transfers-target="deleteModal">
    <div class="fixed inset-0 bg-gray-500/75 dark:bg-gray-900/80 transition-opacity"></div>
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow-xl max-w-md w-full p-6">
        <div class="flex items-start">
          <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 rounded-full bg-red-100 dark:bg-red-900/30">
            <svg class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            </svg>
          </div>
          <div class="ml-4">
            <h3 class="text-lg font-medium text-gray-900 dark:text-white">Delete Recurring Transfer</h3>
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              Are you sure you want to delete this recurring transfer? This action cannot be undone.
            </p>
          </div>
        </div>
        <div class="mt-6 flex justify-end space-x-3">
          <button type="button"
                  class="px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-500 transition"
                  data-action="click->recurring-transfers#cancelDelete">
            Cancel
          </button>
          <button type="button"
                  class="px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition"
                  data-action="click->recurring-transfers#executeDelete">
            Delete
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
